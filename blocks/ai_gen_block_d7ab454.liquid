{% doc %}
  @prompt
    A section for featured collection where I can put Multiple collections in the form multiple tabs where I have option to align and change sizes, The Tab should not look like Buttons and the collection should be separated using a divider between texts, Also there should be an option to show View All Button
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-featured-collections-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-featured-collections__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-featured-collections__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: 40px;
  }

  .ai-featured-collections__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
  }

  .ai-featured-collections__tabs-{{ ai_gen_id }} {
    display: flex;
    justify-content: {{ block.settings.tabs_alignment }};
    gap: 0;
    margin-bottom: 40px;
    flex-wrap: wrap;
    align-items: center;
  }

  .ai-featured-collections__tab-{{ ai_gen_id }} {
    padding: 12px 20px;
    background: none;
    color: {{ block.settings.tab_text_color }};
    border: none;
    cursor: pointer;
    font-size: {{ block.settings.tab_font_size }}px;
    transition: all 0.3s ease;
    position: relative;
  }

  .ai-featured-collections__tab-{{ ai_gen_id }}:hover {
    color: {{ block.settings.tab_hover_text_color }};
  }

  .ai-featured-collections__tab-{{ ai_gen_id }}.active {
    color: {{ block.settings.tab_active_text_color }};
    font-weight: 600;
  }

  .ai-featured-collections__tab-{{ ai_gen_id }}.active::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 20px;
    right: 20px;
    height: {{ block.settings.active_underline_height }}px;
    background-color: {{ block.settings.tab_active_text_color }};
  }

  .ai-featured-collections__divider-{{ ai_gen_id }} {
    width: 1px;
    height: {{ block.settings.divider_height }}px;
    background-color: {{ block.settings.divider_color }};
  }

  .ai-featured-collections__content-{{ ai_gen_id }} {
    display: none;
  }

  .ai-featured-collections__content-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-featured-collections__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.products_per_row }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-featured-collections__view-all-wrapper-{{ ai_gen_id }} {
    text-align: {{ block.settings.view_all_alignment }};
    margin-top: 40px;
  }

  .ai-featured-collections__view-all-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.view_all_padding_vertical }}px {{ block.settings.view_all_padding_horizontal }}px;
    background-color: {{ block.settings.view_all_bg_color }};
    color: {{ block.settings.view_all_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.view_all_border_radius }}px;
    font-size: {{ block.settings.view_all_font_size }}px;
    font-weight: 600;
    transition: all 0.3s ease;
    border: {{ block.settings.view_all_border_width }}px solid {{ block.settings.view_all_border_color }};
  }

  .ai-featured-collections__view-all-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.view_all_hover_bg_color }};
    color: {{ block.settings.view_all_hover_text_color }};
    border-color: {{ block.settings.view_all_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-featured-collections__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.products_per_row_mobile }}, 1fr);
    }

    .ai-featured-collections__tabs-{{ ai_gen_id }} {
      justify-content: center;
    }

    .ai-featured-collections__tab-{{ ai_gen_id }} {
      padding: 10px 15px;
      font-size: {{ block.settings.tab_font_size | times: 0.9 }}px;
    }

    .ai-featured-collections__tab-{{ ai_gen_id }}.active::after {
      left: 15px;
      right: 15px;
    }

    .ai-featured-collections__view-all-wrapper-{{ ai_gen_id }} {
      text-align: center;
    }
  }

  .ai-featured-collections__product-card-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.card_border_radius }}px;
    background-color: {{ block.settings.card_background }};
    transition: transform 0.3s ease;
  }

  .ai-featured-collections__product-card-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
  }

  .ai-featured-collections__product-image-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.image_ratio }};
    overflow: hidden;
  }

  .ai-featured-collections__product-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-featured-collections__product-info-{{ ai_gen_id }} {
    padding: 16px;
    text-align: {{ block.settings.product_info_alignment }};
  }

  .ai-featured-collections__product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    color: {{ block.settings.product_title_color }};
    margin: 0 0 8px;
    font-weight: 600;
  }

  .ai-featured-collections__product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_price_size }}px;
    color: {{ block.settings.product_price_color }};
  }

  .ai-featured-collections__empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #999;
  }

  .ai-featured-collections__empty-state-{{ ai_gen_id }} svg {
    width: 100px;
    height: 100px;
    margin-bottom: 20px;
    opacity: 0.3;
  }
{% endstyle %}

<featured-collections-{{ ai_gen_id }} class="ai-featured-collections-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-featured-collections__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <div class="ai-featured-collections__header-{{ ai_gen_id }}">
        <h2 class="ai-featured-collections__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      </div>
    {% endif %}

    <div class="ai-featured-collections__tabs-{{ ai_gen_id }}">
      {% assign tab_count = 0 %}
      {% for i in (1..5) %}
        {% liquid
          assign collection_key = 'collection_' | append: i
          assign tab_label_key = 'tab_label_' | append: i
          assign collection = block.settings[collection_key]
          assign tab_label = block.settings[tab_label_key]
        %}

        {% if collection != blank %}
          {% assign tab_count = tab_count | plus: 1 %}
          
          {% if tab_count > 1 %}
            <div class="ai-featured-collections__divider-{{ ai_gen_id }}"></div>
          {% endif %}

          <button
            class="ai-featured-collections__tab-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
            data-tab="{{ i }}"
          >
            {% if tab_label != blank %}
              {{ tab_label }}
            {% else %}
              {{ collection.title }}
            {% endif %}
          </button>
        {% endif %}
      {% endfor %}
    </div>

    {% for i in (1..5) %}
      {% liquid
        assign collection_key = 'collection_' | append: i
        assign collection = block.settings[collection_key]
      %}

      {% if collection != blank %}
        <div
          class="ai-featured-collections__content-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
          data-content="{{ i }}"
        >
          {% if collection.products.size > 0 %}
            <div class="ai-featured-collections__grid-{{ ai_gen_id }}">
              {% for product in collection.products limit: block.settings.products_to_show %}
                <a href="{{ product.url }}" class="ai-featured-collections__product-card-{{ ai_gen_id }}">
                  <div class="ai-featured-collections__product-image-{{ ai_gen_id }}">
                    {% if product.featured_image %}
                      <img
                        src="{{ product.featured_image | image_url: width: 600 }}"
                        alt="{{ product.featured_image.alt | escape }}"
                        loading="lazy"
                        width="600"
                        height="600"
                      >
                    {% else %}
                      <div class="ai-featured-collections__image-placeholder-{{ ai_gen_id }}">
                        {{ 'product-1' | placeholder_svg_tag }}
                      </div>
                    {% endif %}
                  </div>
                  <div class="ai-featured-collections__product-info-{{ ai_gen_id }}">
                    <h3 class="ai-featured-collections__product-title-{{ ai_gen_id }}">{{ product.title }}</h3>
                    <div class="ai-featured-collections__product-price-{{ ai_gen_id }}">
                      {{ product.price | money }}
                    </div>
                  </div>
                </a>
              {% endfor %}
            </div>

            {% if block.settings.show_view_all %}
              <div class="ai-featured-collections__view-all-wrapper-{{ ai_gen_id }}">
                <a href="{{ collection.url }}" class="ai-featured-collections__view-all-{{ ai_gen_id }}">
                  {{ block.settings.view_all_text }}
                </a>
              </div>
            {% endif %}
          {% else %}
            <div class="ai-featured-collections__empty-state-{{ ai_gen_id }}">
              {{ 'collection-1' | placeholder_svg_tag }}
              <p>This collection is empty. Add products to display them here.</p>
            </div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</featured-collections-{{ ai_gen_id }}>

<script>
  (function() {
    class FeaturedCollections{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.tabs = this.querySelectorAll('.ai-featured-collections__tab-{{ ai_gen_id }}');
        this.contents = this.querySelectorAll('.ai-featured-collections__content-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.tabs.forEach((tab) => {
          tab.addEventListener('click', () => {
            const tabId = tab.getAttribute('data-tab');
            
            this.tabs.forEach((t) => t.classList.remove('active'));
            this.contents.forEach((c) => c.classList.remove('active'));
            
            tab.classList.add('active');
            const content = this.querySelector(`[data-content="${tabId}"]`);
            if (content) {
              content.classList.add('active');
            }
          });
        });
      }
    }

    customElements.define('featured-collections-{{ ai_gen_id }}', FeaturedCollections{{ ai_gen_id }});
  })();
</script>

