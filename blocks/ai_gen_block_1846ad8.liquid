{% doc %}
  @prompt
    I want a section where I can put multiple subsections as tabs, tabs should not look like buttons. The tabs can be connected to metafields like Country of Origin, Dimensions and Manufacturer, I need alignment option along with animation options
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-tabs-container-{{ ai_gen_id }} {
    width: 100%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-tabs-nav-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.tab_spacing }}px;
    border-bottom: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    margin-bottom: {{ block.settings.content_spacing }}px;
    flex-wrap: wrap;
    {% if block.settings.tab_alignment == 'left' %}
      justify-content: flex-start;
    {% elsif block.settings.tab_alignment == 'center' %}
      justify-content: center;
    {% elsif block.settings.tab_alignment == 'right' %}
      justify-content: flex-end;
    {% endif %}
  }

  .ai-tab-button-{{ ai_gen_id }} {
    background: none;
    border: none;
    padding: {{ block.settings.tab_padding_vertical }}px {{ block.settings.tab_padding_horizontal }}px;
    cursor: pointer;
    font-size: {{ block.settings.tab_font_size }}px;
    color: {{ block.settings.tab_text_color }};
    position: relative;
    transition: color 0.3s ease;
    border-bottom: {{ block.settings.active_indicator_height }}px solid transparent;
    margin-bottom: -{{ block.settings.border_width }}px;
    {% if block.settings.tab_text_transform == 'uppercase' %}
      text-transform: uppercase;
    {% endif %}
  }

  .ai-tab-button-{{ ai_gen_id }}:hover {
    color: {{ block.settings.tab_hover_color }};
  }

  .ai-tab-button-{{ ai_gen_id }}.active {
    color: {{ block.settings.tab_active_color }};
    border-bottom-color: {{ block.settings.active_indicator_color }};
  }

  .ai-tabs-content-{{ ai_gen_id }} {
    position: relative;
    {% if block.settings.content_alignment == 'left' %}
      text-align: left;
    {% elsif block.settings.content_alignment == 'center' %}
      text-align: center;
    {% elsif block.settings.content_alignment == 'right' %}
      text-align: right;
    {% endif %}
  }

  .ai-tab-panel-{{ ai_gen_id }} {
    display: none;
  }

  .ai-tab-panel-{{ ai_gen_id }}.active {
    display: block;
    {% if block.settings.animation_type == 'fade' %}
      animation: ai-fade-in-{{ ai_gen_id }} {{ block.settings.animation_duration }}s ease-in-out;
    {% elsif block.settings.animation_type == 'slide' %}
      animation: ai-slide-in-{{ ai_gen_id }} {{ block.settings.animation_duration }}s ease-in-out;
    {% elsif block.settings.animation_type == 'scale' %}
      animation: ai-scale-in-{{ ai_gen_id }} {{ block.settings.animation_duration }}s ease-in-out;
    {% endif %}
  }

  {% if block.settings.animation_type == 'fade' %}
    @keyframes ai-fade-in-{{ ai_gen_id }} {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }
  {% elsif block.settings.animation_type == 'slide' %}
    @keyframes ai-slide-in-{{ ai_gen_id }} {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  {% elsif block.settings.animation_type == 'scale' %}
    @keyframes ai-scale-in-{{ ai_gen_id }} {
      from {
        opacity: 0;
        transform: scale(0.95);
      }
      to {
        opacity: 1;
        transform: scale(1);
      }
    }
  {% endif %}

  .ai-tab-content-{{ ai_gen_id }} {
    color: {{ block.settings.content_text_color }};
    font-size: {{ block.settings.content_font_size }}px;
    line-height: 1.6;
  }

  .ai-tab-content-{{ ai_gen_id }} h3 {
    margin-top: 0;
    margin-bottom: 12px;
    color: {{ block.settings.content_heading_color }};
  }

  .ai-tab-empty-{{ ai_gen_id }} {
    padding: 40px 20px;
    text-align: center;
    color: #999;
    font-style: italic;
  }

  @media screen and (max-width: 749px) {
    .ai-tabs-nav-{{ ai_gen_id }} {
      gap: {{ block.settings.tab_spacing | times: 0.7 }}px;
      {% if block.settings.mobile_tab_alignment == 'left' %}
        justify-content: flex-start;
      {% elsif block.settings.mobile_tab_alignment == 'center' %}
        justify-content: center;
      {% elsif block.settings.mobile_tab_alignment == 'right' %}
        justify-content: flex-end;
      {% elsif block.settings.mobile_tab_alignment == 'stack' %}
        flex-direction: column;
        align-items: stretch;
      {% endif %}
    }

    .ai-tab-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.tab_font_size | times: 0.9 }}px;
      padding: {{ block.settings.tab_padding_vertical | times: 0.8 }}px {{ block.settings.tab_padding_horizontal | times: 0.8 }}px;
    }

    .ai-tab-content-{{ ai_gen_id }} {
      font-size: {{ block.settings.content_font_size | times: 0.95 }}px;
    }

    {% if block.settings.mobile_tab_alignment == 'stack' %}
      .ai-tab-button-{{ ai_gen_id }} {
        width: 100%;
        text-align: left;
        border-bottom: none;
        border-left: {{ block.settings.active_indicator_height }}px solid transparent;
        margin-bottom: 0;
        margin-left: -{{ block.settings.border_width }}px;
      }

      .ai-tab-button-{{ ai_gen_id }}.active {
        border-bottom-color: transparent;
        border-left-color: {{ block.settings.active_indicator_color }};
      }
    {% endif %}
  }
{% endstyle %}

<product-tabs-{{ ai_gen_id }} class="ai-tabs-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-tabs-nav-{{ ai_gen_id }}" role="tablist">
    {% if block.settings.tab_1_enabled %}
      <button
        class="ai-tab-button-{{ ai_gen_id }} active"
        role="tab"
        aria-selected="true"
        aria-controls="ai-tab-panel-1-{{ ai_gen_id }}"
        data-tab="1"
      >
        {{ block.settings.tab_1_title }}
      </button>
    {% endif %}

    {% if block.settings.tab_2_enabled %}
      <button
        class="ai-tab-button-{{ ai_gen_id }}"
        role="tab"
        aria-selected="false"
        aria-controls="ai-tab-panel-2-{{ ai_gen_id }}"
        data-tab="2"
      >
        {{ block.settings.tab_2_title }}
      </button>
    {% endif %}

    {% if block.settings.tab_3_enabled %}
      <button
        class="ai-tab-button-{{ ai_gen_id }}"
        role="tab"
        aria-selected="false"
        aria-controls="ai-tab-panel-3-{{ ai_gen_id }}"
        data-tab="3"
      >
        {{ block.settings.tab_3_title }}
      </button>
    {% endif %}

    {% if block.settings.tab_4_enabled %}
      <button
        class="ai-tab-button-{{ ai_gen_id }}"
        role="tab"
        aria-selected="false"
        aria-controls="ai-tab-panel-4-{{ ai_gen_id }}"
        data-tab="4"
      >
        {{ block.settings.tab_4_title }}
      </button>
    {% endif %}
  </div>

  <div class="ai-tabs-content-{{ ai_gen_id }}">
    {% if block.settings.tab_1_enabled %}
      <div
        class="ai-tab-panel-{{ ai_gen_id }} active"
        role="tabpanel"
        id="ai-tab-panel-1-{{ ai_gen_id }}"
        data-panel="1"
      >
        <div class="ai-tab-content-{{ ai_gen_id }}">
          {% if block.settings.tab_1_content_type == 'metafield' and block.settings.tab_1_metafield != blank %}
            {{ block.settings.tab_1_metafield }}
          {% elsif block.settings.tab_1_content_type == 'richtext' and block.settings.tab_1_richtext != blank %}
            {{ block.settings.tab_1_richtext }}
          {% else %}
            <div class="ai-tab-empty-{{ ai_gen_id }}">
              Add content for this tab in the block settings
            </div>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% if block.settings.tab_2_enabled %}
      <div
        class="ai-tab-panel-{{ ai_gen_id }}"
        role="tabpanel"
        id="ai-tab-panel-2-{{ ai_gen_id }}"
        data-panel="2"
      >
        <div class="ai-tab-content-{{ ai_gen_id }}">
          {% if block.settings.tab_2_content_type == 'metafield' and block.settings.tab_2_metafield != blank %}
            {{ block.settings.tab_2_metafield }}
          {% elsif block.settings.tab_2_content_type == 'richtext' and block.settings.tab_2_richtext != blank %}
            {{ block.settings.tab_2_richtext }}
          {% else %}
            <div class="ai-tab-empty-{{ ai_gen_id }}">
              Add content for this tab in the block settings
            </div>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% if block.settings.tab_3_enabled %}
      <div
        class="ai-tab-panel-{{ ai_gen_id }}"
        role="tabpanel"
        id="ai-tab-panel-3-{{ ai_gen_id }}"
        data-panel="3"
      >
        <div class="ai-tab-content-{{ ai_gen_id }}">
          {% if block.settings.tab_3_content_type == 'metafield' and block.settings.tab_3_metafield != blank %}
            {{ block.settings.tab_3_metafield }}
          {% elsif block.settings.tab_3_content_type == 'richtext' and block.settings.tab_3_richtext != blank %}
            {{ block.settings.tab_3_richtext }}
          {% else %}
            <div class="ai-tab-empty-{{ ai_gen_id }}">
              Add content for this tab in the block settings
            </div>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% if block.settings.tab_4_enabled %}
      <div
        class="ai-tab-panel-{{ ai_gen_id }}"
        role="tabpanel"
        id="ai-tab-panel-4-{{ ai_gen_id }}"
        data-panel="4"
      >
        <div class="ai-tab-content-{{ ai_gen_id }}">
          {% if block.settings.tab_4_content_type == 'metafield' and block.settings.tab_4_metafield != blank %}
            {{ block.settings.tab_4_metafield }}
          {% elsif block.settings.tab_4_content_type == 'richtext' and block.settings.tab_4_richtext != blank %}
            {{ block.settings.tab_4_richtext }}
          {% else %}
            <div class="ai-tab-empty-{{ ai_gen_id }}">
              Add content for this tab in the block settings
            </div>
          {% endif %}
        </div>
      </div>
    {% endif %}
  </div>
</product-tabs-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductTabs{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.tabButtons = this.querySelectorAll('.ai-tab-button-{{ ai_gen_id }}');
        this.tabPanels = this.querySelectorAll('.ai-tab-panel-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.tabButtons.forEach((button) => {
          button.addEventListener('click', (e) => {
            const tabId = e.currentTarget.getAttribute('data-tab');
            this.switchTab(tabId);
          });
        });
      }

      switchTab(tabId) {
        this.tabButtons.forEach((button) => {
          const isActive = button.getAttribute('data-tab') === tabId;
          button.classList.toggle('active', isActive);
          button.setAttribute('aria-selected', isActive);
        });

        this.tabPanels.forEach((panel) => {
          const isActive = panel.getAttribute('data-panel') === tabId;
          if (isActive) {
            panel.classList.add('active');
          } else {
            panel.classList.remove('active');
          }
        });
      }
    }

    customElements.define('product-tabs-{{ ai_gen_id }}', ProductTabs{{ ai_gen_id }});
  })();
</script>

