{% doc %}
  @prompt
    I need a slide show which is optimised for mobile and desktop, Not optimised for mobile
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-slideshow-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    max-width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-slideshow-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.desktop_height }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    touch-action: pan-y;
  }

  .ai-slideshow-slides-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    transition: transform {{ block.settings.transition_speed }}s ease-in-out;
    will-change: transform;
  }

  .ai-slideshow-slide-{{ ai_gen_id }} {
    position: relative;
    min-width: 100%;
    height: 100%;
    display: flex;
    align-items: {{ block.settings.content_vertical_alignment }};
    justify-content: {{ block.settings.content_horizontal_alignment }};
    opacity: 0;
    transition: opacity 0.5s ease-in-out;
  }

  .ai-slideshow-slide-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-slideshow-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-slideshow-image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-slideshow-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-slideshow-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    padding: 40px;
    text-align: {{ block.settings.text_alignment }};
    max-width: {{ block.settings.content_max_width }}px;
    width: 100%;
    color: {{ block.settings.text_color }};
  }

  .ai-slideshow-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 16px;
    color: {{ block.settings.text_color }};
    line-height: 1.2;
  }

  .ai-slideshow-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    margin: 0 0 24px;
    color: {{ block.settings.text_color }};
    line-height: 1.4;
  }

  .ai-slideshow-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 32px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: background-color 0.3s ease;
    font-size: 16px;
  }

  .ai-slideshow-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-slideshow-nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    background-color: {{ block.settings.nav_background }};
    color: {{ block.settings.nav_color }};
    border: none;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease, opacity 0.3s ease;
    opacity: 0.8;
  }

  .ai-slideshow-nav-{{ ai_gen_id }}:hover {
    opacity: 1;
    background-color: {{ block.settings.nav_hover_background }};
  }

  .ai-slideshow-nav-prev-{{ ai_gen_id }} {
    left: 20px;
  }

  .ai-slideshow-nav-next-{{ ai_gen_id }} {
    right: 20px;
  }

  .ai-slideshow-nav-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
  }

  .ai-slideshow-dots-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    gap: 12px;
    padding: 8px 16px;
    background-color: rgba(0, 0, 0, 0.3);
    border-radius: 20px;
  }

  .ai-slideshow-dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    opacity: 0.5;
    transition: opacity 0.3s ease, transform 0.3s ease;
    padding: 0;
  }

  .ai-slideshow-dot-{{ ai_gen_id }}.active {
    opacity: 1;
    transform: scale(1.3);
  }

  @media screen and (min-width: 750px) {
    .ai-slideshow-{{ ai_gen_id }} {
      width: {{ block.settings.desktop_width_percent }}%;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-slideshow-container-{{ ai_gen_id }} {
      height: {{ block.settings.mobile_height }}px;
      border-radius: 0;
    }

    .ai-slideshow-content-{{ ai_gen_id }} {
      padding: 20px 16px;
      max-width: 100%;
    }

    .ai-slideshow-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 | round }}px;
      margin: 0 0 12px;
    }

    .ai-slideshow-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.75 | round }}px;
      margin: 0 0 16px;
    }

    .ai-slideshow-button-{{ ai_gen_id }} {
      padding: 10px 24px;
      font-size: 14px;
      width: auto;
      display: inline-block;
    }

    .ai-slideshow-nav-{{ ai_gen_id }} {
      width: 36px;
      height: 36px;
      opacity: 0.9;
    }

    .ai-slideshow-nav-prev-{{ ai_gen_id }} {
      left: 8px;
    }

    .ai-slideshow-nav-next-{{ ai_gen_id }} {
      right: 8px;
    }

    .ai-slideshow-nav-{{ ai_gen_id }} svg {
      width: 18px;
      height: 18px;
    }

    .ai-slideshow-dots-{{ ai_gen_id }} {
      bottom: 12px;
      gap: 8px;
      padding: 6px 12px;
    }

    .ai-slideshow-dot-{{ ai_gen_id }} {
      width: 8px;
      height: 8px;
    }
  }

  @media screen and (max-width: 480px) {
    .ai-slideshow-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.5 | round }}px;
    }

    .ai-slideshow-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.7 | round }}px;
    }
  }
{% endstyle %}

<responsive-slideshow-{{ ai_gen_id }}
  class="ai-slideshow-{{ ai_gen_id }}"
  data-autoplay="{{ block.settings.autoplay }}"
  data-autoplay-speed="{{ block.settings.autoplay_speed }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-slideshow-container-{{ ai_gen_id }}">
    <div class="ai-slideshow-slides-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign slide_enabled_key = 'slide_' | append: i | append: '_enabled'
          assign slide_image_key = 'slide_' | append: i | append: '_image'
          assign slide_heading_key = 'slide_' | append: i | append: '_heading'
          assign slide_subheading_key = 'slide_' | append: i | append: '_subheading'
          assign slide_button_text_key = 'slide_' | append: i | append: '_button_text'
          assign slide_button_link_key = 'slide_' | append: i | append: '_button_link'

          assign slide_enabled = block.settings[slide_enabled_key]
          assign slide_image = block.settings[slide_image_key]
          assign slide_heading = block.settings[slide_heading_key]
          assign slide_subheading = block.settings[slide_subheading_key]
          assign slide_button_text = block.settings[slide_button_text_key]
          assign slide_button_link = block.settings[slide_button_link_key]
        %}

        {% if slide_enabled %}
          <div class="ai-slideshow-slide-{{ ai_gen_id }}" data-slide="{{ i }}">
            {% if slide_image %}
              <img
                src="{{ slide_image | image_url: width: 2000 }}"
                srcset="{{ slide_image | image_url: width: 750 }} 750w,
                        {{ slide_image | image_url: width: 1500 }} 1500w,
                        {{ slide_image | image_url: width: 2000 }} 2000w"
                sizes="100vw"
                alt="{{ slide_image.alt | escape }}"
                loading="lazy"
                width="{{ slide_image.width }}"
                height="{{ slide_image.height }}"
                class="ai-slideshow-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-slideshow-image-placeholder-{{ ai_gen_id }}">
                {{ 'hero-apparel-1' | placeholder_svg_tag }}
              </div>
            {% endif %}

            {% if slide_heading != blank or slide_subheading != blank or slide_button_text != blank %}
              <div class="ai-slideshow-content-{{ ai_gen_id }}">
                {% if slide_heading != blank %}
                  <h2 class="ai-slideshow-heading-{{ ai_gen_id }}">{{ slide_heading }}</h2>
                {% endif %}

                {% if slide_subheading != blank %}
                  <p class="ai-slideshow-subheading-{{ ai_gen_id }}">{{ slide_subheading }}</p>
                {% endif %}

                {% if slide_button_text != blank %}
                  <a
                    href="{{ slide_button_link | default: '#' }}"
                    class="ai-slideshow-button-{{ ai_gen_id }}"
                  >
                    {{ slide_button_text }}
                  </a>
                {% endif %}
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if block.settings.show_navigation %}
      <button
        class="ai-slideshow-nav-{{ ai_gen_id }} ai-slideshow-nav-prev-{{ ai_gen_id }}"
        aria-label="Previous slide"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <button
        class="ai-slideshow-nav-{{ ai_gen_id }} ai-slideshow-nav-next-{{ ai_gen_id }}"
        aria-label="Next slide"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    {% endif %}

    {% if block.settings.show_dots %}
      <div class="ai-slideshow-dots-{{ ai_gen_id }}"></div>
    {% endif %}
  </div>
</responsive-slideshow-{{ ai_gen_id }}>

<script>
  (function() {
    class ResponsiveSlideshow{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.slides = [];
        this.autoplayInterval = null;
        this.touchStartX = 0;
        this.touchEndX = 0;
        this.touchStartY = 0;
        this.touchEndY = 0;
        this.isDragging = false;
      }

      connectedCallback() {
        this.slides = Array.from(this.querySelectorAll('.ai-slideshow-slide-{{ ai_gen_id }}'));
        
        if (this.slides.length === 0) return;

        this.slidesContainer = this.querySelector('.ai-slideshow-slides-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-slideshow-nav-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-slideshow-nav-next-{{ ai_gen_id }}');
        this.dotsContainer = this.querySelector('.ai-slideshow-dots-{{ ai_gen_id }}');

        this.setupDots();
        this.setupEventListeners();
        this.showSlide(0);

        const autoplay = this.dataset.autoplay === 'true';
        if (autoplay) {
          this.startAutoplay();
        }
      }

      setupDots() {
        if (!this.dotsContainer) return;

        this.slides.forEach((slide, index) => {
          const dot = document.createElement('button');
          dot.classList.add('ai-slideshow-dot-{{ ai_gen_id }}');
          dot.setAttribute('aria-label', `Go to slide ${index + 1}`);
          dot.addEventListener('click', () => this.goToSlide(index));
          this.dotsContainer.appendChild(dot);
        });

        this.dots = Array.from(this.dotsContainer.querySelectorAll('.ai-slideshow-dot-{{ ai_gen_id }}'));
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.previousSlide());
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.nextSlide());
        }

        this.addEventListener('touchstart', (e) => {
          this.touchStartX = e.changedTouches[0].screenX;
          this.touchStartY = e.changedTouches[0].screenY;
          this.isDragging = true;
        }, { passive: true });

        this.addEventListener('touchmove', (e) => {
          if (!this.isDragging) return;
          
          this.touchEndX = e.changedTouches[0].screenX;
          this.touchEndY = e.changedTouches[0].screenY;
          
          const diffX = Math.abs(this.touchStartX - this.touchEndX);
          const diffY = Math.abs(this.touchStartY - this.touchEndY);
          
          if (diffX > diffY && diffX > 10) {
            e.preventDefault();
          }
        }, { passive: false });

        this.addEventListener('touchend', (e) => {
          if (!this.isDragging) return;
          
          this.touchEndX = e.changedTouches[0].screenX;
          this.touchEndY = e.changedTouches[0].screenY;
          this.handleSwipe();
          this.isDragging = false;
        }, { passive: true });

        this.addEventListener('mouseenter', () => {
          if (this.autoplayInterval) {
            this.stopAutoplay();
          }
        });

        this.addEventListener('mouseleave', () => {
          const autoplay = this.dataset.autoplay === 'true';
          if (autoplay) {
            this.startAutoplay();
          }
        });
      }

      handleSwipe() {
        const swipeThreshold = 50;
        const diffX = this.touchStartX - this.touchEndX;
        const diffY = Math.abs(this.touchStartY - this.touchEndY);

        if (Math.abs(diffX) > swipeThreshold && Math.abs(diffX) > diffY) {
          if (diffX > 0) {
            this.nextSlide();
          } else {
            this.previousSlide();
          }
        }
      }

      showSlide(index) {
        this.slides.forEach((slide, i) => {
          slide.classList.toggle('active', i === index);
        });

        if (this.dots) {
          this.dots.forEach((dot, i) => {
            dot.classList.toggle('active', i === index);
          });
        }

        const offset = -index * 100;
        this.slidesContainer.style.transform = `translateX(${offset}%)`;
        this.currentSlide = index;
      }

      nextSlide() {
        const nextIndex = (this.currentSlide + 1) % this.slides.length;
        this.goToSlide(nextIndex);
      }

      previousSlide() {
        const prevIndex = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.goToSlide(prevIndex);
      }

      goToSlide(index) {
        this.showSlide(index);
        this.resetAutoplay();
      }

      startAutoplay() {
        const speed = parseInt(this.dataset.autoplaySpeed) * 1000;
        this.autoplayInterval = setInterval(() => {
          this.nextSlide();
        }, speed);
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      resetAutoplay() {
        const autoplay = this.dataset.autoplay === 'true';
        if (autoplay) {
          this.stopAutoplay();
          this.startAutoplay();
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('responsive-slideshow-{{ ai_gen_id }}', ResponsiveSlideshow{{ ai_gen_id }});
  })();
</script>

