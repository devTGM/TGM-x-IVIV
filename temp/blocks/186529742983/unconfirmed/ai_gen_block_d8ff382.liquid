      "label": "Arrow color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Dots"
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show dots",
      "default": true
    },
    {
      "type": "range",
      "id": "dot_size",
      "label": "Dot size",
      "min": 6,
      "max": 16,
      "step": 2,
      "unit": "px",
      "default": 10
