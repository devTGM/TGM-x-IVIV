{% doc %}
  @prompt
    Add a block where I can put 4 trust badges, optimised for Mobile and desktop. I need 4 trust badges, I need badges in horizontal on mobile as well as desktop
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-trust-badges-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-trust-badges-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.badge_spacing }}px;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-trust-badge-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: {{ block.settings.icon_text_gap }}px;
    padding: {{ block.settings.badge_padding }}px;
    background-color: {{ block.settings.badge_background }};
    border-radius: {{ block.settings.badge_border_radius }}px;
    transition: transform 0.3s ease;
  }

  .ai-trust-badge-item-{{ ai_gen_id }}:hover {
    transform: translateY(-2px);
  }

  .ai-trust-badge-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
  }

  .ai-trust-badge-icon-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-trust-badge-icon-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
  }

  .ai-trust-badge-icon-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-trust-badge-text-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .ai-trust-badge-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    color: {{ block.settings.title_color }};
    line-height: 1.2;
  }

  .ai-trust-badge-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.4;
  }

  @media screen and (max-width: 749px) {
    .ai-trust-badges-container-{{ ai_gen_id }} {
      grid-template-columns: repeat(4, 1fr);
      gap: {{ block.settings.badge_spacing_mobile }}px;
    }

    .ai-trust-badge-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size_mobile }}px;
      height: {{ block.settings.icon_size_mobile }}px;
    }

    .ai-trust-badge-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_mobile }}px;
    }

    .ai-trust-badge-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size_mobile }}px;
    }
  }
{% endstyle %}

<trust-badges-{{ ai_gen_id }} class="ai-trust-badges-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-trust-badges-container-{{ ai_gen_id }}">
    {% for i in (1..4) %}
      {% liquid
        assign icon_key = 'badge_' | append: i | append: '_icon'
        assign title_key = 'badge_' | append: i | append: '_title'
        assign description_key = 'badge_' | append: i | append: '_description'
        
        assign badge_icon = block.settings[icon_key]
        assign badge_title = block.settings[title_key]
        assign badge_description = block.settings[description_key]
      %}
      
      <div class="ai-trust-badge-item-{{ ai_gen_id }}">
        <div class="ai-trust-badge-icon-{{ ai_gen_id }}">
          {% if badge_icon %}
            <img
              src="{{ badge_icon | image_url: width: 200 }}"
              alt="{{ badge_title | escape }}"
              loading="lazy"
              width="200"
              height="200"
            >
          {% else %}
            <div class="ai-trust-badge-icon-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
        
        <div class="ai-trust-badge-text-{{ ai_gen_id }}">
          {% if badge_title != blank %}
            <div class="ai-trust-badge-title-{{ ai_gen_id }}">{{ badge_title }}</div>
          {% endif %}
          
          {% if badge_description != blank %}
            <div class="ai-trust-badge-description-{{ ai_gen_id }}">{{ badge_description }}</div>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</trust-badges-{{ ai_gen_id }}>

<script>
  (function() {
    class TrustBadges{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('trust-badges-{{ ai_gen_id }}', TrustBadges{{ ai_gen_id }});
  })();
</script>

