{% doc %}
  @prompt
    A category showcase where only one category is visible at a time on mobile in carousel , it shows category in a circles and the size of circles are adjustable, plus the name can be changed, I need bigger circles and all the categories in one line, I need the center aligned, I need all the categories visible on mobile at the same time, I need only 3 Categories
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-category-showcase-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 20px 0;
    overflow-x: auto;
    scrollbar-width: thin;
    margin: 0 auto;
  }

  .ai-category-showcase-{{ ai_gen_id }}::-webkit-scrollbar {
    height: 6px;
  }

  .ai-category-showcase-{{ ai_gen_id }}::-webkit-scrollbar-track {
    background: #f1f1f1;
  }

  .ai-category-showcase-{{ ai_gen_id }}::-webkit-scrollbar-thumb {
    background: #888;
    border-radius: 3px;
  }

  .ai-category-showcase-container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
    justify-content: center;
    width: 100%;
  }

  .ai-category-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .ai-category-circle-{{ ai_gen_id }} {
    width: {{ block.settings.circle_size }}px;
    height: {{ block.settings.circle_size }}px;
    border-radius: 50%;
    overflow: hidden;
    background-color: {{ block.settings.placeholder_bg_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease;
    flex-shrink: 0;
  }

  .ai-category-item-{{ ai_gen_id }}:hover .ai-category-circle-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-category-circle-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-category-circle-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-category-circle-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-category-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    text-align: center;
    font-weight: 500;
  }

  @media screen and (max-width: 749px) {
    .ai-category-showcase-{{ ai_gen_id }} {
      scrollbar-width: none;
      -ms-overflow-style: none;
      padding: 20px 10px;
    }

    .ai-category-showcase-{{ ai_gen_id }}::-webkit-scrollbar {
      display: none;
    }

    .ai-category-showcase-container-{{ ai_gen_id }} {
      justify-content: flex-start;
      gap: {{ block.settings.gap | times: 0.6 }}px;
    }

    .ai-category-circle-{{ ai_gen_id }} {
      width: {{ block.settings.circle_size | times: 0.5 }}px;
      height: {{ block.settings.circle_size | times: 0.5 }}px;
    }

    .ai-category-name-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<category-showcase-{{ ai_gen_id }}
  class="ai-category-showcase-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-category-showcase-container-{{ ai_gen_id }}">
    {% for i in (1..3) %}
      {% liquid
        assign collection_key = 'category_' | append: i
        assign name_key = 'category_name_' | append: i
        assign collection = block.settings[collection_key]
        assign category_name = block.settings[name_key]
      %}

      {% if collection != blank %}
        <a
          href="{{ collection.url }}"
          class="ai-category-item-{{ ai_gen_id }}"
        >
          <div class="ai-category-circle-{{ ai_gen_id }}">
            {% if collection.image %}
              <img
                src="{{ collection.image | image_url: width: 400 }}"
                alt="{{ collection.title | escape }}"
                loading="lazy"
                width="400"
                height="400"
              >
            {% elsif collection.products.first.featured_image %}
              <img
                src="{{ collection.products.first.featured_image | image_url: width: 400 }}"
                alt="{{ collection.title | escape }}"
                loading="lazy"
                width="400"
                height="400"
              >
            {% else %}
              <div class="ai-category-circle-placeholder-{{ ai_gen_id }}">
                {{ 'collection-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          <div class="ai-category-name-{{ ai_gen_id }}">
            {% if category_name != blank %}
              {{ category_name }}
            {% else %}
              {{ collection.title }}
            {% endif %}
          </div>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</category-showcase-{{ ai_gen_id }}>

<script>
  (function() {
    class CategoryShowcase{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.container = this.querySelector('.ai-category-showcase-container-{{ ai_gen_id }}');
        this.setupCarousel();
      }

      setupCarousel() {
        if (!this.container) return;

        let isDown = false;
        let startX;
        let scrollLeft;

        this.addEventListener('mousedown', (e) => {
          isDown = true;
          startX = e.pageX - this.offsetLeft;
          scrollLeft = this.scrollLeft;
        });

        this.addEventListener('mouseleave', () => {
          isDown = false;
        });

        this.addEventListener('mouseup', () => {
          isDown = false;
        });

        this.addEventListener('mousemove', (e) => {
          if (!isDown) return;
          e.preventDefault();
          const x = e.pageX - this.offsetLeft;
          const walk = (x - startX) * 2;
          this.scrollLeft = scrollLeft - walk;
        });
      }
    }

    customElements.define('category-showcase-{{ ai_gen_id }}', CategoryShowcase{{ ai_gen_id }});
  })();
</script>

