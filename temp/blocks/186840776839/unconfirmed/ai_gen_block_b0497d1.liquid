{% doc %}
  @prompt
    A hero banner optimised for mobile and desktop where it takes different images for mobile and desktop view, I need multiples slide with enable and disable option
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-slider-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    display: block;
    overflow: hidden;
  }

  .ai-hero-slider-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.desktop_height }}px;
  }

  .ai-hero-slider-slides-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .ai-hero-slider-slide-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.6s ease-in-out, visibility 0.6s ease-in-out;
  }

  .ai-hero-slider-slide-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
    z-index: 1;
  }

  .ai-hero-slider-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-hero-slider-image-mobile-{{ ai_gen_id }} {
    display: none;
  }

  .ai-hero-slider-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .ai-hero-slider-content-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    padding: 40px;
    z-index: 2;
  }

  .ai-hero-slider-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 16px;
    max-width: 800px;
  }

  .ai-hero-slider-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    margin: 0 0 24px;
    max-width: 600px;
  }

  .ai-hero-slider-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 32px;
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    transition: background-color 0.3s ease;
    width: fit-content;
  }

  .ai-hero-slider-controls-{{ ai_gen_id }} {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 12px;
    z-index: 3;
  }

  .ai-hero-slider-dot-{{ ai_gen_id }} {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: 0.5;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .ai-hero-slider-dot-{{ ai_gen_id }}.active {
    opacity: 1;
    transform: scale(1.2);
  }

  .ai-hero-slider-arrows-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
  }

  .ai-hero-slider-arrow-{{ ai_gen_id }} {
    background-color: {{ block.settings.arrow_background }};
    color: {{ block.settings.arrow_color }};
    border: none;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease;
  }

  .ai-hero-slider-arrow-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.arrow_hover_background }};
  }

  .ai-hero-slider-arrow-prev-{{ ai_gen_id }} {
    left: 20px;
  }

  .ai-hero-slider-arrow-next-{{ ai_gen_id }} {
    right: 20px;
  }

  .ai-hero-slider-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-hero-slider-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 600px;
    max-height: 400px;
  }

  .ai-hero-slider-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-hero-slider-container-{{ ai_gen_id }} {
      height: {{ block.settings.mobile_height }}px;
    }

    .ai-hero-slider-image-desktop-{{ ai_gen_id }} {
      display: none;
    }

    .ai-hero-slider-image-mobile-{{ ai_gen_id }} {
      display: block;
    }

    .ai-hero-slider-content-{{ ai_gen_id }} {
      padding: 24px;
    }

    .ai-hero-slider-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
      margin-bottom: 12px;
    }

    .ai-hero-slider-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.8 }}px;
      margin-bottom: 16px;
    }

    .ai-hero-slider-button-{{ ai_gen_id }} {
      padding: 12px 24px;
      font-size: {{ block.settings.button_text_size | times: 0.9 }}px;
    }

    .ai-hero-slider-arrow-{{ ai_gen_id }} {
      width: 40px;
      height: 40px;
    }

    .ai-hero-slider-arrow-prev-{{ ai_gen_id }} {
      left: 10px;
    }

    .ai-hero-slider-arrow-next-{{ ai_gen_id }} {
      right: 10px;
    }
  }
{% endstyle %}

<hero-slider-{{ ai_gen_id }} class="ai-hero-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-slider-container-{{ ai_gen_id }}">
    <div class="ai-hero-slider-slides-{{ ai_gen_id }}">
      {% liquid
        assign has_slides = false
        for i in (1..5)
          assign slide_enabled_key = 'slide_' | append: i | append: '_enabled'
          if block.settings[slide_enabled_key]
            assign has_slides = true
            break
          endif
        endfor
      %}

      {% if has_slides %}
        {% for i in (1..5) %}
          {% liquid
            assign slide_enabled_key = 'slide_' | append: i | append: '_enabled'
            assign desktop_image_key = 'slide_' | append: i | append: '_desktop_image'
            assign mobile_image_key = 'slide_' | append: i | append: '_mobile_image'
            assign heading_key = 'slide_' | append: i | append: '_heading'
            assign subheading_key = 'slide_' | append: i | append: '_subheading'
            assign button_text_key = 'slide_' | append: i | append: '_button_text'
            assign button_link_key = 'slide_' | append: i | append: '_button_link'
            assign overlay_color_key = 'slide_' | append: i | append: '_overlay_color'
            assign overlay_opacity_key = 'slide_' | append: i | append: '_overlay_opacity'
            assign heading_color_key = 'slide_' | append: i | append: '_heading_color'
            assign text_color_key = 'slide_' | append: i | append: '_text_color'
            assign button_bg_key = 'slide_' | append: i | append: '_button_bg'
            assign button_text_color_key = 'slide_' | append: i | append: '_button_text_color'
            assign button_hover_bg_key = 'slide_' | append: i | append: '_button_hover_bg'
            assign content_v_align_key = 'slide_' | append: i | append: '_content_v_align'
            assign content_h_align_key = 'slide_' | append: i | append: '_content_h_align'
            assign text_align_key = 'slide_' | append: i | append: '_text_align'

            assign slide_enabled = block.settings[slide_enabled_key]
            assign desktop_image = block.settings[desktop_image_key]
            assign mobile_image = block.settings[mobile_image_key]
            assign heading = block.settings[heading_key]
            assign subheading = block.settings[subheading_key]
            assign button_text = block.settings[button_text_key]
            assign button_link = block.settings[button_link_key]
            assign overlay_color = block.settings[overlay_color_key]
            assign overlay_opacity = block.settings[overlay_opacity_key]
            assign heading_color = block.settings[heading_color_key]
            assign text_color = block.settings[text_color_key]
            assign button_bg = block.settings[button_bg_key]
            assign button_text_color = block.settings[button_text_color_key]
            assign button_hover_bg = block.settings[button_hover_bg_key]
            assign content_v_align = block.settings[content_v_align_key]
            assign content_h_align = block.settings[content_h_align_key]
            assign text_align = block.settings[text_align_key]
          %}

          {% if slide_enabled %}
            <div class="ai-hero-slider-slide-{{ ai_gen_id }}" data-slide="{{ i }}">
              {% if desktop_image or mobile_image %}
                {% if desktop_image %}
                  <img
                    src="{{ desktop_image | image_url: width: 2000 }}"
                    alt="{{ desktop_image.alt | escape }}"
                    loading="lazy"
                    width="{{ desktop_image.width }}"
                    height="{{ desktop_image.height }}"
                    class="ai-hero-slider-image-{{ ai_gen_id }} ai-hero-slider-image-desktop-{{ ai_gen_id }}"
                  >
                {% endif %}

                {% if mobile_image %}
                  <img
                    src="{{ mobile_image | image_url: width: 1000 }}"
                    alt="{{ mobile_image.alt | escape }}"
                    loading="lazy"
                    width="{{ mobile_image.width }}"
                    height="{{ mobile_image.height }}"
                    class="ai-hero-slider-image-{{ ai_gen_id }} ai-hero-slider-image-mobile-{{ ai_gen_id }}"
                  >
                {% elsif desktop_image %}
                  <img
                    src="{{ desktop_image | image_url: width: 1000 }}"
                    alt="{{ desktop_image.alt | escape }}"
                    loading="lazy"
                    width="{{ desktop_image.width }}"
                    height="{{ desktop_image.height }}"
                    class="ai-hero-slider-image-{{ ai_gen_id }} ai-hero-slider-image-mobile-{{ ai_gen_id }}"
                  >
                {% endif %}
              {% else %}
                <div class="ai-hero-slider-placeholder-{{ ai_gen_id }}">
                  {{ 'hero-apparel-1' | placeholder_svg_tag }}
                </div>
              {% endif %}

              <div
                class="ai-hero-slider-overlay-{{ ai_gen_id }}"
                style="background-color: {{ overlay_color }}; opacity: {{ overlay_opacity }};"
              ></div>

              <div
                class="ai-hero-slider-content-{{ ai_gen_id }}"
                style="justify-content: {{ content_v_align }}; align-items: {{ content_h_align }}; text-align: {{ text_align }};"
              >
                {% if heading != blank %}
                  <h2 class="ai-hero-slider-heading-{{ ai_gen_id }}" style="color: {{ heading_color }};">
                    {{ heading }}
                  </h2>
                {% endif %}

                {% if subheading != blank %}
                  <div class="ai-hero-slider-subheading-{{ ai_gen_id }}" style="color: {{ text_color }};">
                    {{ subheading }}
                  </div>
                {% endif %}

                {% if button_text != blank and button_link != blank %}
                  <a
                    href="{{ button_link }}"
                    class="ai-hero-slider-button-{{ ai_gen_id }}"
                    style="background-color: {{ button_bg }}; color: {{ button_text_color }};"
                    onmouseover="this.style.backgroundColor='{{ button_hover_bg }}'"
                    onmouseout="this.style.backgroundColor='{{ button_bg }}'"
                  >
                    {{ button_text }}
                  </a>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      {% else %}
        <div class="ai-hero-slider-slide-{{ ai_gen_id }} active">
          <div class="ai-hero-slider-placeholder-{{ ai_gen_id }}">
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
            <div class="ai-hero-slider-empty-state-{{ ai_gen_id }}">
              Next, enable and configure slides
            </div>
          </div>
        </div>
      {% endif %}
    </div>

    {% if has_slides and block.settings.show_arrows %}
      <div class="ai-hero-slider-arrows-{{ ai_gen_id }} ai-hero-slider-arrow-prev-{{ ai_gen_id }}">
        <button class="ai-hero-slider-arrow-{{ ai_gen_id }}" data-direction="prev" aria-label="Previous slide">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
      </div>
      <div class="ai-hero-slider-arrows-{{ ai_gen_id }} ai-hero-slider-arrow-next-{{ ai_gen_id }}">
        <button class="ai-hero-slider-arrow-{{ ai_gen_id }}" data-direction="next" aria-label="Next slide">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      </div>
    {% endif %}

    {% if has_slides and block.settings.show_dots %}
      <div class="ai-hero-slider-controls-{{ ai_gen_id }}"></div>
    {% endif %}
  </div>
</hero-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class HeroSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.slides = [];
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.style.display = 'block';
        this.slides = Array.from(this.querySelectorAll('.ai-hero-slider-slide-{{ ai_gen_id }}'));
        
        if (this.slides.length === 0) return;

        this.slides = this.slides.filter(slide => slide.dataset.slide);

        if (this.slides.length === 0) return;

        this.setupDots();
        this.setupArrows();
        this.showSlide(0);

        {% if block.settings.autoplay %}
          this.startAutoplay();
        {% endif %}
      }

      setupDots() {
        const dotsContainer = this.querySelector('.ai-hero-slider-controls-{{ ai_gen_id }}');
        if (!dotsContainer) return;

        dotsContainer.innerHTML = '';
        this.slides.forEach((slide, index) => {
          const dot = document.createElement('button');
          dot.className = 'ai-hero-slider-dot-{{ ai_gen_id }}';
          dot.setAttribute('aria-label', `Go to slide ${index + 1}`);
          dot.addEventListener('click', () => {
            this.showSlide(index);
            this.resetAutoplay();
          });
          dotsContainer.appendChild(dot);
        });
      }

      setupArrows() {
        const arrows = this.querySelectorAll('.ai-hero-slider-arrow-{{ ai_gen_id }}');
        arrows.forEach(arrow => {
          arrow.addEventListener('click', () => {
            const direction = arrow.dataset.direction;
            if (direction === 'prev') {
              this.prevSlide();
            } else {
              this.nextSlide();
            }
            this.resetAutoplay();
          });
        });
      }

      showSlide(index) {
        this.slides.forEach(slide => slide.classList.remove('active'));
        const dots = this.querySelectorAll('.ai-hero-slider-dot-{{ ai_gen_id }}');
        dots.forEach(dot => dot.classList.remove('active'));

        this.currentSlide = index;
        this.slides[this.currentSlide].classList.add('active');
        if (dots[this.currentSlide]) {
          dots[this.currentSlide].classList.add('active');
        }
      }

      nextSlide() {
        const next = (this.currentSlide + 1) % this.slides.length;
        this.showSlide(next);
      }

      prevSlide() {
        const prev = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.showSlide(prev);
      }

      startAutoplay() {
        this.autoplayInterval = setInterval(() => {
          this.nextSlide();
        }, {{ block.settings.autoplay_speed }} * 1000);
      }

      resetAutoplay() {
        {% if block.settings.autoplay %}
          if (this.autoplayInterval) {
            clearInterval(this.autoplayInterval);
          }
          this.startAutoplay();
        {% endif %}
      }

      disconnectedCallback() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
        }
      }
    }

    customElements.define('hero-slider-{{ ai_gen_id }}', HeroSlider{{ ai_gen_id }});
  })();
</script>

