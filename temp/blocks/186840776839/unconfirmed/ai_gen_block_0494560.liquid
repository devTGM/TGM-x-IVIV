{% doc %}
  @prompt
    A hero banner optimised for mobile and desktop where it takes different images for mobile and desktop view, I need multiples slide with enable and disable option, I need transparent header
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-transparent-header-{{ ai_gen_id }} {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    transition: background-color 0.3s ease, backdrop-filter 0.3s ease;
    display: block;
  }

  .ai-transparent-header-{{ ai_gen_id }}.scrolled {
    background-color: {{ block.settings.scrolled_bg_color }};
    backdrop-filter: blur({{ block.settings.blur_amount }}px);
  }

  .ai-transparent-header-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .ai-transparent-header-logo-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
  }

  .ai-transparent-header-logo-{{ ai_gen_id }} img {
    height: {{ block.settings.logo_height }}px;
    width: auto;
  }

  .ai-transparent-header-logo-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.logo_text_size }}px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .ai-transparent-header-{{ ai_gen_id }}.scrolled .ai-transparent-header-logo-text-{{ ai_gen_id }} {
    color: {{ block.settings.scrolled_text_color }};
  }

  .ai-transparent-header-nav-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.nav_gap }}px;
    align-items: center;
  }

  .ai-transparent-header-nav-link-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    text-decoration: none;
    font-size: {{ block.settings.nav_text_size }}px;
    transition: color 0.3s ease;
    padding: 8px 12px;
  }

  .ai-transparent-header-nav-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.hover_color }};
  }

  .ai-transparent-header-{{ ai_gen_id }}.scrolled .ai-transparent-header-nav-link-{{ ai_gen_id }} {
    color: {{ block.settings.scrolled_text_color }};
  }

  .ai-transparent-header-{{ ai_gen_id }}.scrolled .ai-transparent-header-nav-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.scrolled_hover_color }};
  }

  .ai-transparent-header-mobile-toggle-{{ ai_gen_id }} {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: {{ block.settings.text_color }};
    transition: color 0.3s ease;
  }

  .ai-transparent-header-{{ ai_gen_id }}.scrolled .ai-transparent-header-mobile-toggle-{{ ai_gen_id }} {
    color: {{ block.settings.scrolled_text_color }};
  }

  .ai-transparent-header-mobile-menu-{{ ai_gen_id }} {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    background-color: {{ block.settings.mobile_menu_bg }};
    z-index: 999;
    padding: 80px 24px 24px;
    overflow-y: auto;
  }

  .ai-transparent-header-mobile-menu-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-transparent-header-mobile-close-{{ ai_gen_id }} {
    position: absolute;
    top: 20px;
    right: 20px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: {{ block.settings.mobile_menu_text_color }};
  }

  .ai-transparent-header-mobile-nav-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-transparent-header-mobile-nav-link-{{ ai_gen_id }} {
    color: {{ block.settings.mobile_menu_text_color }};
    text-decoration: none;
    font-size: {{ block.settings.mobile_nav_text_size }}px;
    padding: 16px;
    border-bottom: 1px solid {{ block.settings.mobile_menu_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-transparent-header-nav-{{ ai_gen_id }} {
      display: none;
    }

    .ai-transparent-header-mobile-toggle-{{ ai_gen_id }} {
      display: block;
    }

    .ai-transparent-header-container-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_padding_vertical }}px {{ block.settings.mobile_padding_horizontal }}px;
    }

    .ai-transparent-header-logo-{{ ai_gen_id }} img {
      height: {{ block.settings.mobile_logo_height }}px;
    }

    .ai-transparent-header-logo-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_logo_text_size }}px;
    }
  }
{% endstyle %}

<transparent-header-{{ ai_gen_id }} class="ai-transparent-header-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-transparent-header-container-{{ ai_gen_id }}">
    <div class="ai-transparent-header-logo-{{ ai_gen_id }}">
      {% if block.settings.logo %}
        <a href="/">
          <img
            src="{{ block.settings.logo | image_url: width: 400 }}"
            alt="{{ shop.name }}"
            loading="lazy"
            width="{{ block.settings.logo.width }}"
            height="{{ block.settings.logo.height }}"
          >
        </a>
      {% elsif block.settings.logo_text != blank %}
        <a href="/" class="ai-transparent-header-logo-text-{{ ai_gen_id }}">
          {{ block.settings.logo_text }}
        </a>
      {% else %}
        <a href="/" class="ai-transparent-header-logo-text-{{ ai_gen_id }}">
          {{ shop.name }}
        </a>
      {% endif %}
    </div>

    <nav class="ai-transparent-header-nav-{{ ai_gen_id }}">
      {% if block.settings.nav_link_1_text != blank %}
        <a href="{{ block.settings.nav_link_1_url }}" class="ai-transparent-header-nav-link-{{ ai_gen_id }}">
          {{ block.settings.nav_link_1_text }}
        </a>
      {% endif %}

      {% if block.settings.nav_link_2_text != blank %}
        <a href="{{ block.settings.nav_link_2_url }}" class="ai-transparent-header-nav-link-{{ ai_gen_id }}">
          {{ block.settings.nav_link_2_text }}
        </a>
      {% endif %}

      {% if block.settings.nav_link_3_text != blank %}
        <a href="{{ block.settings.nav_link_3_url }}" class="ai-transparent-header-nav-link-{{ ai_gen_id }}">
          {{ block.settings.nav_link_3_text }}
        </a>
      {% endif %}

      {% if block.settings.nav_link_4_text != blank %}
        <a href="{{ block.settings.nav_link_4_url }}" class="ai-transparent-header-nav-link-{{ ai_gen_id }}">
          {{ block.settings.nav_link_4_text }}
        </a>
      {% endif %}

      {% if block.settings.nav_link_5_text != blank %}
        <a href="{{ block.settings.nav_link_5_url }}" class="ai-transparent-header-nav-link-{{ ai_gen_id }}">
          {{ block.settings.nav_link_5_text }}
        </a>
      {% endif %}
    </nav>

    <button class="ai-transparent-header-mobile-toggle-{{ ai_gen_id }}" aria-label="Open menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </div>

  <div class="ai-transparent-header-mobile-menu-{{ ai_gen_id }}">
    <button class="ai-transparent-header-mobile-close-{{ ai_gen_id }}" aria-label="Close menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>

    <nav class="ai-transparent-header-mobile-nav-{{ ai_gen_id }}">
      {% if block.settings.nav_link_1_text != blank %}
        <a href="{{ block.settings.nav_link_1_url }}" class="ai-transparent-header-mobile-nav-link-{{ ai_gen_id }}">
          {{ block.settings.nav_link_1_text }}
        </a>
      {% endif %}

      {% if block.settings.nav_link_2_text != blank %}
        <a href="{{ block.settings.nav_link_2_url }}" class="ai-transparent-header-mobile-nav-link-{{ ai_gen_id }}">
          {{ block.settings.nav_link_2_text }}
        </a>
      {% endif %}

      {% if block.settings.nav_link_3_text != blank %}
        <a href="{{ block.settings.nav_link_3_url }}" class="ai-transparent-header-mobile-nav-link-{{ ai_gen_id }}">
          {{ block.settings.nav_link_3_text }}
        </a>
      {% endif %}

      {% if block.settings.nav_link_4_text != blank %}
        <a href="{{ block.settings.nav_link_4_url }}" class="ai-transparent-header-mobile-nav-link-{{ ai_gen_id }}">
          {{ block.settings.nav_link_4_text }}
        </a>
      {% endif %}

      {% if block.settings.nav_link_5_text != blank %}
        <a href="{{ block.settings.nav_link_5_url }}" class="ai-transparent-header-mobile-nav-link-{{ ai_gen_id }}">
          {{ block.settings.nav_link_5_text }}
        </a>
      {% endif %}
    </nav>
  </div>
</transparent-header-{{ ai_gen_id }}>

<script>
  (function() {
    class TransparentHeader{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.scrollThreshold = {{ block.settings.scroll_threshold }};
      }

      connectedCallback() {
        this.style.display = 'block';
        this.setupScrollListener();
        this.setupMobileMenu();
      }

      setupScrollListener() {
        window.addEventListener('scroll', () => {
          if (window.scrollY > this.scrollThreshold) {
            this.classList.add('scrolled');
          } else {
            this.classList.remove('scrolled');
          }
        });
      }

      setupMobileMenu() {
        const toggleButton = this.querySelector('.ai-transparent-header-mobile-toggle-{{ ai_gen_id }}');
        const closeButton = this.querySelector('.ai-transparent-header-mobile-close-{{ ai_gen_id }}');
        const mobileMenu = this.querySelector('.ai-transparent-header-mobile-menu-{{ ai_gen_id }}');
        const mobileLinks = this.querySelectorAll('.ai-transparent-header-mobile-nav-link-{{ ai_gen_id }}');

        if (toggleButton && mobileMenu) {
          toggleButton.addEventListener('click', () => {
            mobileMenu.classList.add('active');
            document.body.style.overflow = 'hidden';
          });
        }

        if (closeButton && mobileMenu) {
          closeButton.addEventListener('click', () => {
            mobileMenu.classList.remove('active');
            document.body.style.overflow = '';
          });
        }

        mobileLinks.forEach(link => {
          link.addEventListener('click', () => {
            mobileMenu.classList.remove('active');
            document.body.style.overflow = '';
          });
        });
      }

      disconnectedCallback() {
        document.body.style.overflow = '';
      }
    }

    customElements.define('transparent-header-{{ ai_gen_id }}', TransparentHeader{{ ai_gen_id }});
  })();
</script>

