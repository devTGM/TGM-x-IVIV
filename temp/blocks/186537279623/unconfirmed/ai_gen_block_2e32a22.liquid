{% doc %}
  @prompt
    I need an image with text section which has image on left or right and content on the other side. Also Optimise it for mobile and desktop, I need multiple slides in Image, I need content as well, I want on the content on left or right side not on the image , Now one change instead of one image make multiple slides and keep rest as asmae, Need control option for arrows and dots, The text should be Same for all and It should be Rich Text 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-carousel-text-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    position: relative;
  }

  .ai-carousel-text-container-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-carousel-text-slides-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-carousel-text-slide-{{ ai_gen_id }} {
    display: none;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .ai-carousel-text-slide-{{ ai_gen_id }}.active {
    display: block;
    opacity: 1;
  }

  .ai-carousel-text-wrapper-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
    align-items: {{ block.settings.vertical_alignment }};
    {% if block.settings.image_position == 'right' %}
      flex-direction: row-reverse;
    {% endif %}
  }

  .ai-carousel-text-image-column-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.image_width }}%;
  }

  .ai-carousel-text-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
  }

  .ai-carousel-text-image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .ai-carousel-text-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-carousel-text-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-carousel-text-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-carousel-text-content-column-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: {{ block.settings.content_vertical_alignment }};
  }

  .ai-carousel-text-content-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-carousel-text-heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    line-height: 1.2;
  }

  .ai-carousel-text-richtext-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    margin: 0 0 {{ block.settings.text_spacing }}px;
    line-height: 1.6;
  }

  .ai-carousel-text-richtext-{{ ai_gen_id }} p {
    margin: 0 0 16px;
  }

  .ai-carousel-text-richtext-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-carousel-text-richtext-{{ ai_gen_id }} h1,
  .ai-carousel-text-richtext-{{ ai_gen_id }} h2,
  .ai-carousel-text-richtext-{{ ai_gen_id }} h3,
  .ai-carousel-text-richtext-{{ ai_gen_id }} h4,
  .ai-carousel-text-richtext-{{ ai_gen_id }} h5,
  .ai-carousel-text-richtext-{{ ai_gen_id }} h6 {
    margin: 0 0 12px;
  }

  .ai-carousel-text-richtext-{{ ai_gen_id }} ul,
  .ai-carousel-text-richtext-{{ ai_gen_id }} ol {
    margin: 0 0 16px;
    padding-left: 20px;
  }

  .ai-carousel-text-richtext-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
    text-decoration: underline;
  }

  .ai-carousel-text-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    transition: background-color 0.3s ease;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
  }

  .ai-carousel-text-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-carousel-text-controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: {{ block.settings.controls_spacing }}px;
  }

  .ai-carousel-text-nav-{{ ai_gen_id }} {
    display: {% if block.settings.show_arrows %}flex{% else %}none{% endif %};
    gap: 10px;
  }

  .ai-carousel-text-nav-button-{{ ai_gen_id }} {
    background-color: {{ block.settings.nav_button_background }};
    color: {{ block.settings.nav_button_color }};
    border: {{ block.settings.nav_button_border_width }}px solid {{ block.settings.nav_button_border_color }};
    width: 44px;
    height: 44px;
    border-radius: {{ block.settings.nav_button_border_radius }}px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .ai-carousel-text-nav-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_button_hover_background }};
    color: {{ block.settings.nav_button_hover_color }};
    border-color: {{ block.settings.nav_button_hover_border_color }};
  }

  .ai-carousel-text-nav-button-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  .ai-carousel-text-dots-{{ ai_gen_id }} {
    display: {% if block.settings.show_dots %}flex{% else %}none{% endif %};
    gap: 8px;
    align-items: center;
  }

  .ai-carousel-text-dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    cursor: pointer;
    transition: all 0.3s ease;
    border: none;
    padding: 0;
  }

  .ai-carousel-text-dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
    transform: scale(1.2);
  }

  @media screen and (max-width: 749px) {
    .ai-carousel-text-container-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_padding_top }}px {{ block.settings.mobile_padding_horizontal }}px {{ block.settings.mobile_padding_bottom }}px;
    }

    .ai-carousel-text-wrapper-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.mobile_gap }}px;
    }

    .ai-carousel-text-image-column-{{ ai_gen_id }} {
      flex: 0 0 100%;
    }

    .ai-carousel-text-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_heading_size }}px;
    }

    .ai-carousel-text-richtext-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_text_size }}px;
    }

    .ai-carousel-text-content-{{ ai_gen_id }} {
      text-align: {{ block.settings.mobile_text_alignment }};
    }
  }
{% endstyle %}

<carousel-with-text-{{ ai_gen_id }} class="ai-carousel-text-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-carousel-text-container-{{ ai_gen_id }}">
    <div class="ai-carousel-text-slides-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign image_key = 'slide_' | append: i | append: '_image'
          assign slide_image = block.settings[image_key]
        %}

        <div class="ai-carousel-text-slide-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}" data-slide="{{ forloop.index }}">
          <div class="ai-carousel-text-wrapper-{{ ai_gen_id }}">
            <div class="ai-carousel-text-image-column-{{ ai_gen_id }}">
              <div class="ai-carousel-text-image-wrapper-{{ ai_gen_id }}">
                {% if slide_image %}
                  <img
                    src="{{ slide_image | image_url: width: 1500 }}"
                    alt="{{ slide_image.alt | escape }}"
                    loading="lazy"
                    width="{{ slide_image.width }}"
                    height="{{ slide_image.height }}"
                  >
                {% else %}
                  <div class="ai-carousel-text-placeholder-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                    <div class="ai-carousel-text-empty-state-{{ ai_gen_id }}">
                      Add image for slide {{ forloop.index }}
                    </div>
                  </div>
                {% endif %}
              </div>
            </div>

            <div class="ai-carousel-text-content-column-{{ ai_gen_id }}">
              <div class="ai-carousel-text-content-{{ ai_gen_id }}">
                {% if block.settings.heading != blank %}
                  <h2 class="ai-carousel-text-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
                {% endif %}

                {% if block.settings.text != blank %}
                  <div class="ai-carousel-text-richtext-{{ ai_gen_id }}">{{ block.settings.text }}</div>
                {% endif %}

                {% if block.settings.button_text != blank %}
                  <a href="{{ block.settings.button_link }}" class="ai-carousel-text-button-{{ ai_gen_id }}">
                    {{ block.settings.button_text }}
                  </a>
                {% endif %}
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

    {% if block.settings.show_arrows or block.settings.show_dots %}
      <div class="ai-carousel-text-controls-{{ ai_gen_id }}">
        <div class="ai-carousel-text-nav-{{ ai_gen_id }}">
          <button class="ai-carousel-text-nav-button-{{ ai_gen_id }} ai-carousel-text-prev-{{ ai_gen_id }}" aria-label="Previous slide">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
          </button>
          <button class="ai-carousel-text-nav-button-{{ ai_gen_id }} ai-carousel-text-next-{{ ai_gen_id }}" aria-label="Next slide">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </button>
        </div>

        <div class="ai-carousel-text-dots-{{ ai_gen_id }}">
          {% for i in (1..5) %}
            <button class="ai-carousel-text-dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}" data-slide="{{ forloop.index }}" aria-label="Go to slide {{ forloop.index }}"></button>
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>
</carousel-with-text-{{ ai_gen_id }}>

<script>
  (function() {
    class CarouselWithText{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 1;
        this.totalSlides = 5;
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.slides = this.querySelectorAll('.ai-carousel-text-slide-{{ ai_gen_id }}');
        this.dots = this.querySelectorAll('.ai-carousel-text-dot-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-carousel-text-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-carousel-text-next-{{ ai_gen_id }}');

        if (this.prevButton && this.nextButton) {
          this.prevButton.addEventListener('click', () => this.previousSlide());
          this.nextButton.addEventListener('click', () => this.nextSlide());
        }

        this.dots.forEach((dot) => {
          dot.addEventListener('click', (e) => {
            const slideNumber = parseInt(e.target.dataset.slide);
            this.goToSlide(slideNumber);
          });
        });

        {% if block.settings.autoplay %}
          this.startAutoplay();
          this.addEventListener('mouseenter', () => this.stopAutoplay());
          this.addEventListener('mouseleave', () => this.startAutoplay());
        {% endif %}
      }

      goToSlide(slideNumber) {
        this.slides.forEach((slide) => {
          slide.classList.remove('active');
        });

        this.dots.forEach((dot) => {
          dot.classList.remove('active');
        });

        this.slides[slideNumber - 1].classList.add('active');
        if (this.dots[slideNumber - 1]) {
          this.dots[slideNumber - 1].classList.add('active');
        }
        this.currentSlide = slideNumber;
      }

      nextSlide() {
        let nextSlide = this.currentSlide + 1;
        if (nextSlide > this.totalSlides) {
          nextSlide = 1;
        }
        this.goToSlide(nextSlide);
      }

      previousSlide() {
        let prevSlide = this.currentSlide - 1;
        if (prevSlide < 1) {
          prevSlide = this.totalSlides;
        }
        this.goToSlide(prevSlide);
      }

      startAutoplay() {
        this.autoplayInterval = setInterval(() => {
          this.nextSlide();
        }, {{ block.settings.autoplay_speed }} * 1000);
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('carousel-with-text-{{ ai_gen_id }}', CarouselWithText{{ ai_gen_id }});
  })();
</script>

