{% doc %}
  @prompt
    I need an image with text section which has image on left or right and content on the other side. Also Optimise it for mobile and desktop, I need multiple slides in Image, I need content as well
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-carousel-content-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-carousel-content-container-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-carousel-content-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-carousel-content-slides-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.5s ease-in-out;
  }

  .ai-carousel-content-slide-{{ ai_gen_id }} {
    min-width: 100%;
    position: relative;
  }

  .ai-carousel-content-slide-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .ai-carousel-content-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-carousel-content-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-carousel-content-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-carousel-content-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: {{ block.settings.content_vertical_alignment }};
    justify-content: {{ block.settings.content_horizontal_alignment }};
    padding: 40px;
    background: {{ block.settings.overlay_color }};
  }

  .ai-carousel-content-text-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-carousel-content-heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    line-height: 1.2;
  }

  .ai-carousel-content-subheading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    margin: 0 0 {{ block.settings.text_spacing }}px;
    line-height: 1.5;
  }

  .ai-carousel-content-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    transition: background-color 0.3s ease;
  }

  .ai-carousel-content-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-carousel-content-nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.nav_background }};
    color: {{ block.settings.nav_color }};
    border: none;
    width: {{ block.settings.nav_size }}px;
    height: {{ block.settings.nav_size }}px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
    transition: background-color 0.3s ease;
  }

  .ai-carousel-content-nav-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_hover_background }};
  }

  .ai-carousel-content-nav-prev-{{ ai_gen_id }} {
    left: {{ block.settings.nav_offset }}px;
  }

  .ai-carousel-content-nav-next-{{ ai_gen_id }} {
    right: {{ block.settings.nav_offset }}px;
  }

  .ai-carousel-content-nav-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
  }

  .ai-carousel-content-dots-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: {{ block.settings.dots_spacing }}px;
  }

  .ai-carousel-content-dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background-color 0.3s ease, transform 0.3s ease;
  }

  .ai-carousel-content-dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
    transform: scale(1.2);
  }

  @media screen and (max-width: 749px) {
    .ai-carousel-content-container-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_padding_top }}px {{ block.settings.mobile_padding_horizontal }}px {{ block.settings.mobile_padding_bottom }}px;
    }

    .ai-carousel-content-overlay-{{ ai_gen_id }} {
      padding: 20px;
    }

    .ai-carousel-content-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_heading_size }}px;
    }

    .ai-carousel-content-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_text_size }}px;
    }

    .ai-carousel-content-nav-{{ ai_gen_id }} {
      width: {{ block.settings.mobile_nav_size }}px;
      height: {{ block.settings.mobile_nav_size }}px;
    }

    .ai-carousel-content-nav-prev-{{ ai_gen_id }} {
      left: {{ block.settings.mobile_nav_offset }}px;
    }

    .ai-carousel-content-nav-next-{{ ai_gen_id }} {
      right: {{ block.settings.mobile_nav_offset }}px;
    }
  }
{% endstyle %}

<carousel-with-content-{{ ai_gen_id }} class="ai-carousel-content-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-carousel-content-container-{{ ai_gen_id }}">
    <div class="ai-carousel-content-wrapper-{{ ai_gen_id }}">
      <div class="ai-carousel-content-slides-{{ ai_gen_id }}">
        {% for i in (1..5) %}
          {% assign image_key = 'image_' | append: i %}
          {% assign heading_key = 'heading_' | append: i %}
          {% assign text_key = 'text_' | append: i %}
          {% assign button_text_key = 'button_text_' | append: i %}
          {% assign button_link_key = 'button_link_' | append: i %}
          
          {% assign slide_image = block.settings[image_key] %}
          {% assign slide_heading = block.settings[heading_key] %}
          {% assign slide_text = block.settings[text_key] %}
          {% assign slide_button_text = block.settings[button_text_key] %}
          {% assign slide_button_link = block.settings[button_link_key] %}

          {% if slide_image or i == 1 %}
            <div class="ai-carousel-content-slide-{{ ai_gen_id }}">
              {% if slide_image %}
                <img
                  src="{{ slide_image | image_url: width: 2000 }}"
                  alt="{{ slide_image.alt | escape }}"
                  loading="lazy"
                  width="{{ slide_image.width }}"
                  height="{{ slide_image.height }}"
                >
              {% else %}
                <div class="ai-carousel-content-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                  <div class="ai-carousel-content-empty-state-{{ ai_gen_id }}">
                    Add slide {{ i }} image
                  </div>
                </div>
              {% endif %}

              {% if slide_heading != blank or slide_text != blank or slide_button_text != blank %}
                <div class="ai-carousel-content-overlay-{{ ai_gen_id }}">
                  <div class="ai-carousel-content-text-{{ ai_gen_id }}">
                    {% if slide_heading != blank %}
                      <h2 class="ai-carousel-content-heading-{{ ai_gen_id }}">{{ slide_heading }}</h2>
                    {% endif %}
                    {% if slide_text != blank %}
                      <div class="ai-carousel-content-subheading-{{ ai_gen_id }}">{{ slide_text }}</div>
                    {% endif %}
                    {% if slide_button_text != blank %}
                      <a href="{{ slide_button_link }}" class="ai-carousel-content-button-{{ ai_gen_id }}">
                        {{ slide_button_text }}
                      </a>
                    {% endif %}
                  </div>
                </div>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>

      {% if block.settings.show_arrows %}
        <button class="ai-carousel-content-nav-{{ ai_gen_id }} ai-carousel-content-nav-prev-{{ ai_gen_id }}" aria-label="Previous slide">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
        <button class="ai-carousel-content-nav-{{ ai_gen_id }} ai-carousel-content-nav-next-{{ ai_gen_id }}" aria-label="Next slide">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      {% endif %}
    </div>

    {% if block.settings.show_dots %}
      <div class="ai-carousel-content-dots-{{ ai_gen_id }}"></div>
    {% endif %}
  </div>
</carousel-with-content-{{ ai_gen_id }}>

<script>
  (function() {
    class CarouselWithContent{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.slidesContainer = this.querySelector('.ai-carousel-content-slides-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-carousel-content-slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-carousel-content-nav-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-carousel-content-nav-next-{{ ai_gen_id }}');
        this.dotsContainer = this.querySelector('.ai-carousel-content-dots-{{ ai_gen_id }}');
        
        this.totalSlides = this.slides.length;

        if (this.totalSlides <= 1) {
          if (this.prevButton) this.prevButton.style.display = 'none';
          if (this.nextButton) this.nextButton.style.display = 'none';
          return;
        }

        this.setupEventListeners();
        this.createDots();
        this.updateSlide();

        {% if block.settings.autoplay %}
          this.startAutoplay();
        {% endif %}
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.prevSlide());
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.nextSlide());
        }

        let touchStartX = 0;
        let touchEndX = 0;

        this.slidesContainer.addEventListener('touchstart', (e) => {
          touchStartX = e.changedTouches[0].screenX;
        });

        this.slidesContainer.addEventListener('touchend', (e) => {
          touchEndX = e.changedTouches[0].screenX;
          this.handleSwipe(touchStartX, touchEndX);
        });
      }

      createDots() {
        if (!this.dotsContainer) return;

        for (let i = 0; i < this.totalSlides; i++) {
          const dot = document.createElement('button');
          dot.classList.add('ai-carousel-content-dot-{{ ai_gen_id }}');
          dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
          dot.addEventListener('click', () => this.goToSlide(i));
          this.dotsContainer.appendChild(dot);
        }

        this.dots = this.querySelectorAll('.ai-carousel-content-dot-{{ ai_gen_id }}');
      }

      updateSlide() {
        const offset = -this.currentSlide * 100;
        this.slidesContainer.style.transform = `translateX(${offset}%)`;

        if (this.dots) {
          this.dots.forEach((dot, index) => {
            if (index === this.currentSlide) {
              dot.classList.add('active');
            } else {
              dot.classList.remove('active');
            }
          });
        }
      }

      nextSlide() {
        this.currentSlide = (this.currentSlide + 1) % this.totalSlides;
        this.updateSlide();
        this.resetAutoplay();
      }

      prevSlide() {
        this.currentSlide = (this.currentSlide - 1 + this.totalSlides) % this.totalSlides;
        this.updateSlide();
        this.resetAutoplay();
      }

      goToSlide(index) {
        this.currentSlide = index;
        this.updateSlide();
        this.resetAutoplay();
      }

      handleSwipe(startX, endX) {
        const swipeThreshold = 50;
        const diff = startX - endX;

        if (Math.abs(diff) > swipeThreshold) {
          if (diff > 0) {
            this.nextSlide();
          } else {
            this.prevSlide();
          }
        }
      }

      startAutoplay() {
        this.autoplayInterval = setInterval(() => {
          this.nextSlide();
        }, {{ block.settings.autoplay_speed }} * 1000);
      }

      resetAutoplay() {
        {% if block.settings.autoplay %}
          if (this.autoplayInterval) {
            clearInterval(this.autoplayInterval);
            this.startAutoplay();
          }
        {% endif %}
      }

      disconnectedCallback() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
        }
      }
    }

    customElements.define('carousel-with-content-{{ ai_gen_id }}', CarouselWithContent{{ ai_gen_id }});
  })();
</script>

