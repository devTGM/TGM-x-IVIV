{% doc %}
  @prompt
    i want to showcase the categories where the the featured image is shown in circular badge and their name below that, I want carousel on mobile and want option to adjust the size of the circles, I want one category to been at once
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-category-showcase-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-category-showcase__container-{{ ai_gen_id }} {
    width: 100%;
  }

  .ai-category-showcase__heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
  }

  .ai-category-showcase__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    width: 100%;
  }

  .ai-category-showcase__carousel-{{ ai_gen_id }} {
    display: none;
  }

  .ai-category-showcase__item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    text-decoration: none;
    transition: transform 0.3s ease;
  }

  .ai-category-showcase__item-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
  }

  .ai-category-showcase__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.image_size_desktop }}px;
    height: {{ block.settings.image_size_desktop }}px;
    border-radius: 50%;
    overflow: hidden;
    margin-bottom: {{ block.settings.name_spacing }}px;
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    background-color: {{ block.settings.image_background }};
  }

  .ai-category-showcase__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-category-showcase__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-category-showcase__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-category-showcase__name-{{ ai_gen_id }} {
    color: {{ block.settings.name_color }};
    font-size: {{ block.settings.name_size }}px;
    font-weight: {{ block.settings.name_weight }};
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-category-showcase__grid-{{ ai_gen_id }} {
      {% if block.settings.enable_mobile_carousel %}
        display: none;
      {% else %}
        grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      {% endif %}
    }

    .ai-category-showcase__carousel-{{ ai_gen_id }} {
      {% if block.settings.enable_mobile_carousel %}
        display: block;
        position: relative;
        overflow: hidden;
      {% endif %}
    }

    .ai-category-showcase__carousel-track-{{ ai_gen_id }} {
      display: flex;
      gap: {{ block.settings.carousel_gap }}px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding: 0 calc((100% - {{ block.settings.image_size_mobile }}px) / 2);
    }

    .ai-category-showcase__carousel-track-{{ ai_gen_id }}::-webkit-scrollbar {
      display: none;
    }

    .ai-category-showcase__carousel-item-{{ ai_gen_id }} {
      flex: 0 0 auto;
      scroll-snap-align: center;
      width: {{ block.settings.image_size_mobile }}px;
    }

    .ai-category-showcase__carousel-{{ ai_gen_id }} .ai-category-showcase__image-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.image_size_mobile }}px;
      height: {{ block.settings.image_size_mobile }}px;
    }

    .ai-category-showcase__carousel-dots-{{ ai_gen_id }} {
      display: flex;
      justify-content: center;
      gap: 8px;
      margin-top: 20px;
    }

    .ai-category-showcase__dot-{{ ai_gen_id }} {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background-color: {{ block.settings.dot_color }};
      opacity: 0.3;
      transition: opacity 0.3s ease;
    }

    .ai-category-showcase__dot-{{ ai_gen_id }}.active {
      opacity: 1;
    }
  }
{% endstyle %}

<category-showcase-{{ ai_gen_id }}
  class="ai-category-showcase-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-category-showcase__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-category-showcase__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    <div class="ai-category-showcase__grid-{{ ai_gen_id }}">
      {% for i in (1..8) %}
        {% liquid
          assign collection_key = 'collection_' | append: i
          assign collection = block.settings[collection_key]
        %}

        {% if collection != blank %}
          <a
            href="{{ collection.url }}"
            class="ai-category-showcase__item-{{ ai_gen_id }}"
          >
            <div class="ai-category-showcase__image-wrapper-{{ ai_gen_id }}">
              {% if collection.featured_image %}
                <img
                  src="{{ collection.featured_image | image_url: width: 400 }}"
                  alt="{{ collection.featured_image.alt | default: collection.title | escape }}"
                  class="ai-category-showcase__image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="400"
                  height="400"
                >
              {% else %}
                <div class="ai-category-showcase__placeholder-{{ ai_gen_id }}">
                  {{ 'collection-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            <h3 class="ai-category-showcase__name-{{ ai_gen_id }}">
              {{ collection.title }}
            </h3>
          </a>
        {% endif %}
      {% endfor %}
    </div>

    <div class="ai-category-showcase__carousel-{{ ai_gen_id }}">
      <div class="ai-category-showcase__carousel-track-{{ ai_gen_id }}" data-carousel-track>
        {% for i in (1..8) %}
          {% liquid
            assign collection_key = 'collection_' | append: i
            assign collection = block.settings[collection_key]
          %}

          {% if collection != blank %}
            <div class="ai-category-showcase__carousel-item-{{ ai_gen_id }}">
              <a
                href="{{ collection.url }}"
                class="ai-category-showcase__item-{{ ai_gen_id }}"
              >
                <div class="ai-category-showcase__image-wrapper-{{ ai_gen_id }}">
                  {% if collection.featured_image %}
                    <img
                      src="{{ collection.featured_image | image_url: width: 400 }}"
                      alt="{{ collection.featured_image.alt | default: collection.title | escape }}"
                      class="ai-category-showcase__image-{{ ai_gen_id }}"
                      loading="lazy"
                      width="400"
                      height="400"
                    >
                  {% else %}
                    <div class="ai-category-showcase__placeholder-{{ ai_gen_id }}">
                      {{ 'collection-1' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </div>
                <h3 class="ai-category-showcase__name-{{ ai_gen_id }}">
                  {{ collection.title }}
                </h3>
              </a>
            </div>
          {% endif %}
        {% endfor %}
      </div>
      {% if block.settings.show_carousel_dots %}
        <div class="ai-category-showcase__carousel-dots-{{ ai_gen_id }}" data-carousel-dots></div>
      {% endif %}
    </div>
  </div>
</category-showcase-{{ ai_gen_id }}>

<script>
  (function() {
    class CategoryShowcase{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.carouselTrack = null;
        this.carouselDots = null;
        this.items = [];
        this.currentIndex = 0;
      }

      connectedCallback() {
        this.style.display = 'block';
        this.initCarousel();
      }

      initCarousel() {
        this.carouselTrack = this.querySelector('[data-carousel-track]');
        this.carouselDots = this.querySelector('[data-carousel-dots]');

        if (!this.carouselTrack) return;

        this.items = Array.from(this.carouselTrack.querySelectorAll('.ai-category-showcase__carousel-item-{{ ai_gen_id }}'));

        if (this.items.length === 0) return;

        if (this.carouselDots) {
          this.createDots();
        }

        this.carouselTrack.addEventListener('scroll', this.handleScroll.bind(this));
      }

      createDots() {
        this.items.forEach((item, index) => {
          const dot = document.createElement('div');
          dot.className = 'ai-category-showcase__dot-{{ ai_gen_id }}';
          if (index === 0) {
            dot.classList.add('active');
          }
          this.carouselDots.appendChild(dot);
        });
      }

      handleScroll() {
        if (!this.carouselTrack || this.items.length === 0) return;

        const scrollLeft = this.carouselTrack.scrollLeft;
        const trackWidth = this.carouselTrack.offsetWidth;
        const itemWidth = this.items[0].offsetWidth;
        const gap = {{ block.settings.carousel_gap }};
        const centerOffset = (trackWidth - itemWidth) / 2;
        const newIndex = Math.round((scrollLeft - centerOffset + itemWidth / 2) / (itemWidth + gap));
        const clampedIndex = Math.max(0, Math.min(newIndex, this.items.length - 1));

        if (clampedIndex !== this.currentIndex) {
          this.currentIndex = clampedIndex;
          this.updateDots();
        }
      }

      updateDots() {
        if (!this.carouselDots) return;

        const dots = this.carouselDots.querySelectorAll('.ai-category-showcase__dot-{{ ai_gen_id }}');
        dots.forEach((dot, index) => {
          if (index === this.currentIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }
    }

    customElements.define('category-showcase-{{ ai_gen_id }}', CategoryShowcase{{ ai_gen_id }});
  })();
</script>

