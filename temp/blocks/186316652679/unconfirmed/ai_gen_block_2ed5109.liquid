{% doc %}
  @prompt
    I want a trust icon section which is horizontal on desktop and shows a carousel on mobile , I need 5-7 icons and Text should have a bold or unbold option, Also Need an option to enable or Disable them, I want option to hide dots on mobile also I need oprion to show arrows as well
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-trust-icons-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-trust-icons-container-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: {{ block.settings.icon_spacing }}px;
    padding: 0 20px;
  }

  .ai-trust-icon-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: {{ block.settings.text_spacing }}px;
    flex: 1;
    min-width: 0;
  }

  .ai-trust-icon-image-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
  }

  .ai-trust-icon-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-trust-icon-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
  }

  .ai-trust-icon-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-trust-icon-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.4;
    {% if block.settings.text_bold %}
      font-weight: 700;
    {% else %}
      font-weight: 400;
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    .ai-trust-icons-container-{{ ai_gen_id }} {
      display: none;
    }

    .ai-trust-icons-carousel-{{ ai_gen_id }} {
      display: block;
      position: relative;
      overflow: hidden;
      padding: 0 {% if block.settings.show_arrows %}60{% else %}20{% endif %}px;
    }

    .ai-trust-icons-carousel-track-{{ ai_gen_id }} {
      display: flex;
      transition: transform 0.3s ease;
    }

    .ai-trust-icon-slide-{{ ai_gen_id }} {
      min-width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: {{ block.settings.text_spacing }}px;
    }

    .ai-trust-icons-dots-{{ ai_gen_id }} {
      display: {% if block.settings.show_dots %}flex{% else %}none{% endif %};
      justify-content: center;
      gap: 8px;
      margin-top: 20px;
    }

    .ai-trust-icons-dot-{{ ai_gen_id }} {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background-color: {{ block.settings.text_color }};
      opacity: 0.3;
      border: none;
      padding: 0;
      cursor: pointer;
      transition: opacity 0.3s ease;
    }

    .ai-trust-icons-dot-{{ ai_gen_id }}.active {
      opacity: 1;
    }

    .ai-trust-icons-arrow-{{ ai_gen_id }} {
      display: {% if block.settings.show_arrows %}flex{% else %}none{% endif %};
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      width: 40px;
      height: 40px;
      background-color: {{ block.settings.arrow_background }};
      color: {{ block.settings.arrow_color }};
      border: none;
      border-radius: 50%;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      z-index: 2;
      transition: opacity 0.3s ease;
    }

    .ai-trust-icons-arrow-{{ ai_gen_id }}:active {
      opacity: 0.7;
    }

    .ai-trust-icons-arrow-prev-{{ ai_gen_id }} {
      left: 10px;
    }

    .ai-trust-icons-arrow-next-{{ ai_gen_id }} {
      right: 10px;
    }

    .ai-trust-icons-arrow-{{ ai_gen_id }} svg {
      width: 20px;
      height: 20px;
    }
  }

  @media screen and (min-width: 750px) {
    .ai-trust-icons-carousel-{{ ai_gen_id }} {
      display: none;
    }
  }
{% endstyle %}

<trust-icons-{{ ai_gen_id }} class="ai-trust-icons-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-trust-icons-container-{{ ai_gen_id }}">
    {% for i in (1..7) %}
      {% liquid
        assign enabled_key = 'icon_' | append: i | append: '_enabled'
        assign icon_key = 'icon_' | append: i
        assign text_key = 'text_' | append: i
        assign enabled = block.settings[enabled_key]
        assign icon = block.settings[icon_key]
        assign text = block.settings[text_key]
      %}
      
      {% if enabled %}
        <div class="ai-trust-icon-item-{{ ai_gen_id }}">
          <div class="ai-trust-icon-image-wrapper-{{ ai_gen_id }}">
            {% if icon %}
              <img
                src="{{ icon | image_url: width: 200 }}"
                alt="{{ text | escape }}"
                class="ai-trust-icon-image-{{ ai_gen_id }}"
                loading="lazy"
                width="200"
                height="200"
              >
            {% else %}
              <div class="ai-trust-icon-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          {% if text != blank %}
            <div class="ai-trust-icon-text-{{ ai_gen_id }}">{{ text }}</div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <div class="ai-trust-icons-carousel-{{ ai_gen_id }}">
    {% if block.settings.show_arrows %}
      <button class="ai-trust-icons-arrow-{{ ai_gen_id }} ai-trust-icons-arrow-prev-{{ ai_gen_id }}" aria-label="Previous slide">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button class="ai-trust-icons-arrow-{{ ai_gen_id }} ai-trust-icons-arrow-next-{{ ai_gen_id }}" aria-label="Next slide">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    {% endif %}

    <div class="ai-trust-icons-carousel-track-{{ ai_gen_id }}">
      {% for i in (1..7) %}
        {% liquid
          assign enabled_key = 'icon_' | append: i | append: '_enabled'
          assign icon_key = 'icon_' | append: i
          assign text_key = 'text_' | append: i
          assign enabled = block.settings[enabled_key]
          assign icon = block.settings[icon_key]
          assign text = block.settings[text_key]
        %}
        
        {% if enabled %}
          <div class="ai-trust-icon-slide-{{ ai_gen_id }}" data-slide-index="{{ i }}">
            <div class="ai-trust-icon-image-wrapper-{{ ai_gen_id }}">
              {% if icon %}
                <img
                  src="{{ icon | image_url: width: 200 }}"
                  alt="{{ text | escape }}"
                  class="ai-trust-icon-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="200"
                  height="200"
                >
              {% else %}
                <div class="ai-trust-icon-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            {% if text != blank %}
              <div class="ai-trust-icon-text-{{ ai_gen_id }}">{{ text }}</div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
    
    <div class="ai-trust-icons-dots-{{ ai_gen_id }}">
      {% assign dot_index = 0 %}
      {% for i in (1..7) %}
        {% liquid
          assign enabled_key = 'icon_' | append: i | append: '_enabled'
          assign enabled = block.settings[enabled_key]
        %}
        {% if enabled %}
          <button
            class="ai-trust-icons-dot-{{ ai_gen_id }} {% if dot_index == 0 %}active{% endif %}"
            data-index="{{ dot_index }}"
            aria-label="Go to slide {{ dot_index | plus: 1 }}"
          ></button>
          {% assign dot_index = dot_index | plus: 1 %}
        {% endif %}
      {% endfor %}
    </div>
  </div>
</trust-icons-{{ ai_gen_id }}>

<script>
  (function() {
    class TrustIcons{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-trust-icons-carousel-track-{{ ai_gen_id }}');
        this.dots = this.querySelectorAll('.ai-trust-icons-dot-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-trust-icon-slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-trust-icons-arrow-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-trust-icons-arrow-next-{{ ai_gen_id }}');
        this.totalSlides = this.slides.length;
        
        if (this.track && this.totalSlides > 0) {
          this.setupEventListeners();
          this.startAutoplay();
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => {
            this.stopAutoplay();
            this.prevSlide();
            this.startAutoplay();
          });
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => {
            this.stopAutoplay();
            this.nextSlide();
            this.startAutoplay();
          });
        }

        this.dots.forEach((dot) => {
          dot.addEventListener('click', (e) => {
            this.stopAutoplay();
            const index = parseInt(e.target.dataset.index);
            this.goToSlide(index);
            this.startAutoplay();
          });
        });

        let touchStartX = 0;
        let touchEndX = 0;

        this.track.addEventListener('touchstart', (e) => {
          touchStartX = e.changedTouches[0].screenX;
        });

        this.track.addEventListener('touchend', (e) => {
          touchEndX = e.changedTouches[0].screenX;
          this.handleSwipe(touchStartX, touchEndX);
        });
      }

      handleSwipe(startX, endX) {
        const swipeThreshold = 50;
        const diff = startX - endX;

        if (Math.abs(diff) > swipeThreshold) {
          this.stopAutoplay();
          if (diff > 0) {
            this.nextSlide();
          } else {
            this.prevSlide();
          }
          this.startAutoplay();
        }
      }

      goToSlide(index) {
        this.currentSlide = index;
        this.updateCarousel();
      }

      nextSlide() {
        if (this.totalSlides > 0) {
          this.currentSlide = (this.currentSlide + 1) % this.totalSlides;
          this.updateCarousel();
        }
      }

      prevSlide() {
        if (this.totalSlides > 0) {
          this.currentSlide = (this.currentSlide - 1 + this.totalSlides) % this.totalSlides;
          this.updateCarousel();
        }
      }

      updateCarousel() {
        const offset = -this.currentSlide * 100;
        this.track.style.transform = `translateX(${offset}%)`;

        this.dots.forEach((dot, index) => {
          if (index === this.currentSlide) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }

      startAutoplay() {
        if (this.totalSlides > 1) {
          this.autoplayInterval = setInterval(() => {
            this.nextSlide();
          }, 3000);
        }
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }
    }

    customElements.define('trust-icons-{{ ai_gen_id }}', TrustIcons{{ ai_gen_id }});
  })();
</script>

