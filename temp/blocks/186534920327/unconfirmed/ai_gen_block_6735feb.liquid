{% doc %}
  @prompt
    Need Image section with multiple slides
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-slider-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    overflow: hidden;
  }

  .ai-image-slider__container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.slider_height }}px;
  }

  .ai-image-slider__track-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.5s ease;
    height: 100%;
  }

  .ai-image-slider__slide-{{ ai_gen_id }} {
    min-width: 100%;
    height: 100%;
    position: relative;
  }

  .ai-image-slider__slide-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-image-slider__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-image-slider__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-image-slider__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-image-slider__nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.nav_button_color }};
    color: {{ block.settings.nav_button_icon_color }};
    border: none;
    width: {{ block.settings.nav_button_size }}px;
    height: {{ block.settings.nav_button_size }}px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: opacity 0.3s ease;
    opacity: {{ block.settings.nav_button_opacity | divided_by: 100.0 }};
  }

  .ai-image-slider__nav-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  .ai-image-slider__nav-{{ ai_gen_id }}--prev {
    left: {{ block.settings.nav_button_offset }}px;
  }

  .ai-image-slider__nav-{{ ai_gen_id }}--next {
    right: {{ block.settings.nav_button_offset }}px;
  }

  .ai-image-slider__nav-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.nav_button_size }}px * 0.5);
    height: calc({{ block.settings.nav_button_size }}px * 0.5);
  }

  .ai-image-slider__dots-{{ ai_gen_id }} {
    position: absolute;
    bottom: {{ block.settings.dots_offset }}px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 10;
  }

  .ai-image-slider__dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    opacity: {{ block.settings.dot_opacity | divided_by: 100.0 }};
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .ai-image-slider__dot-{{ ai_gen_id }}.active {
    opacity: 1;
    transform: scale(1.2);
  }

  @media screen and (max-width: 749px) {
    .ai-image-slider__container-{{ ai_gen_id }} {
      height: {{ block.settings.slider_height_mobile }}px;
    }

    .ai-image-slider__nav-{{ ai_gen_id }} {
      width: calc({{ block.settings.nav_button_size }}px * 0.8);
      height: calc({{ block.settings.nav_button_size }}px * 0.8);
    }

    .ai-image-slider__nav-{{ ai_gen_id }} svg {
      width: calc({{ block.settings.nav_button_size }}px * 0.4);
      height: calc({{ block.settings.nav_button_size }}px * 0.4);
    }
  }
{% endstyle %}

<image-slider-{{ ai_gen_id }} class="ai-image-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-slider__container-{{ ai_gen_id }}">
    <div class="ai-image-slider__track-{{ ai_gen_id }}">
      {% liquid
        assign has_images = false
        for i in (1..5)
          assign image_key = 'image_' | append: i
          if block.settings[image_key] != blank
            assign has_images = true
            break
          endif
        endfor
      %}

      {% if has_images %}
        {% for i in (1..5) %}
          {% liquid
            assign image_key = 'image_' | append: i
            assign image = block.settings[image_key]
          %}
          {% if image != blank %}
            <div class="ai-image-slider__slide-{{ ai_gen_id }}" data-slide="{{ forloop.index0 }}">
              <img
                src="{{ image | image_url: width: 2000 }}"
                alt="{{ image.alt | escape }}"
                loading="lazy"
                width="{{ image.width }}"
                height="{{ image.height }}"
              >
            </div>
          {% endif %}
        {% endfor %}
      {% else %}
        <div class="ai-image-slider__slide-{{ ai_gen_id }}" data-slide="0">
          <div class="ai-image-slider__placeholder-{{ ai_gen_id }}">
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
            <div class="ai-image-slider__empty-state-{{ ai_gen_id }}">
              Next, add images to your slider
            </div>
          </div>
        </div>
      {% endif %}
    </div>

    {% if has_images and block.settings.show_navigation %}
      <button
        class="ai-image-slider__nav-{{ ai_gen_id }} ai-image-slider__nav-{{ ai_gen_id }}--prev"
        aria-label="Previous slide"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button
        class="ai-image-slider__nav-{{ ai_gen_id }} ai-image-slider__nav-{{ ai_gen_id }}--next"
        aria-label="Next slide"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    {% endif %}

    {% if has_images and block.settings.show_dots %}
      <div class="ai-image-slider__dots-{{ ai_gen_id }}">
        {% for i in (1..5) %}
          {% liquid
            assign image_key = 'image_' | append: i
            assign image = block.settings[image_key]
          %}
          {% if image != blank %}
            <button
              class="ai-image-slider__dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
              aria-label="Go to slide {{ forloop.index }}"
              data-slide="{{ forloop.index0 }}"
            ></button>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</image-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-image-slider__track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-image-slider__slide-{{ ai_gen_id }}');
        this.dots = this.querySelectorAll('.ai-image-slider__dot-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-image-slider__nav-{{ ai_gen_id }}--prev');
        this.nextButton = this.querySelector('.ai-image-slider__nav-{{ ai_gen_id }}--next');
        this.autoplay = {{ block.settings.autoplay }};
        this.autoplaySpeed = {{ block.settings.autoplay_speed }} * 1000;

        if (this.slides.length <= 1) return;

        this.setupEventListeners();
        
        if (this.autoplay) {
          this.startAutoplay();
          this.addEventListener('mouseenter', () => this.stopAutoplay());
          this.addEventListener('mouseleave', () => this.startAutoplay());
        }
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.goToPrevSlide());
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.goToNextSlide());
        }

        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => this.goToSlide(index));
        });

        let touchStartX = 0;
        let touchEndX = 0;

        this.addEventListener('touchstart', (e) => {
          touchStartX = e.changedTouches[0].screenX;
        });

        this.addEventListener('touchend', (e) => {
          touchEndX = e.changedTouches[0].screenX;
          this.handleSwipe(touchStartX, touchEndX);
        });
      }

      handleSwipe(startX, endX) {
        const swipeThreshold = 50;
        const diff = startX - endX;

        if (Math.abs(diff) > swipeThreshold) {
          if (diff > 0) {
            this.goToNextSlide();
          } else {
            this.goToPrevSlide();
          }
        }
      }

      goToSlide(index) {
        this.currentSlide = index;
        this.updateSlider();
      }

      goToNextSlide() {
        this.currentSlide = (this.currentSlide + 1) % this.slides.length;
        this.updateSlider();
      }

      goToPrevSlide() {
        this.currentSlide = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.updateSlider();
      }

      updateSlider() {
        const offset = -this.currentSlide * 100;
        this.track.style.transform = 'translateX(' + offset + '%)';

        this.dots.forEach((dot, index) => {
          if (index === this.currentSlide) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }

      startAutoplay() {
        if (!this.autoplay || this.slides.length <= 1) return;
        
        this.autoplayInterval = setInterval(() => {
          this.goToNextSlide();
        }, this.autoplaySpeed);
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('image-slider-{{ ai_gen_id }}', ImageSlider{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Image slider",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1"
