{% doc %}
  @prompt
    Design an Image with text section which has option to insert multiple slides on left or right and content on the other side.
    
    Please make it mobile and desktop optimised 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-text-slider-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-image-text-slider-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-image-text-slider-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.gap }}px;
    {% if block.settings.layout == 'image_right' %}
      flex-direction: row-reverse;
    {% endif %}
  }

  .ai-image-text-slider-slides-{{ ai_gen_id }} {
    flex: 1;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-image-text-slider-track-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.5s ease;
  }

  .ai-image-text-slider-slide-{{ ai_gen_id }} {
    min-width: 100%;
    flex-shrink: 0;
  }

  .ai-image-text-slider-slide-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-image-text-slider-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-image-text-slider-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-image-text-slider-controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
    margin-top: 20px;
  }

  .ai-image-text-slider-arrow-{{ ai_gen_id }} {
    background-color: {{ block.settings.arrow_background }};
    color: {{ block.settings.arrow_color }};
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-image-text-slider-arrow-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.arrow_hover_background }};
    color: {{ block.settings.arrow_hover_color }};
  }

  .ai-image-text-slider-arrow-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-image-text-slider-dots-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-image-text-slider-dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .ai-image-text-slider-dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
    transform: scale(1.2);
  }

  .ai-image-text-slider-content-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ai-image-text-slider-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
    line-height: 1.2;
  }

  .ai-image-text-slider-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
  }

  .ai-image-text-slider-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 32px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    transition: all 0.3s ease;
    text-align: center;
    border: none;
    cursor: pointer;
  }

  .ai-image-text-slider-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
  }

  @media screen and (max-width: 768px) {
    .ai-image-text-slider-wrapper-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 30px;
    }

    .ai-image-text-slider-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-image-text-slider-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }

    .ai-image-text-slider-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_text_size | times: 0.9 }}px;
      padding: 12px 24px;
    }
  }
{% endstyle %}

<image-text-slider-{{ ai_gen_id }}
  class="ai-image-text-slider-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-image-text-slider-container-{{ ai_gen_id }}">
    <div class="ai-image-text-slider-wrapper-{{ ai_gen_id }}">
      <div class="ai-image-text-slider-slides-{{ ai_gen_id }}">
        <div class="ai-image-text-slider-track-{{ ai_gen_id }}">
          {% if block.settings.image_1 != blank or block.settings.image_2 != blank or block.settings.image_3 != blank or block.settings.image_4 != blank or block.settings.image_5 != blank %}
            {% for i in (1..5) %}
              {% assign image_key = 'image_' | append: i %}
              {% assign image = block.settings[image_key] %}
              {% if image != blank %}
                <div class="ai-image-text-slider-slide-{{ ai_gen_id }}">
                  <img
                    src="{{ image | image_url: width: 1200 }}"
                    alt="{{ image.alt | escape }}"
                    loading="lazy"
                    width="{{ image.width }}"
                    height="{{ image.height }}"
                  >
                </div>
              {% endif %}
            {% endfor %}
          {% else %}
            <div class="ai-image-text-slider-slide-{{ ai_gen_id }}">
              <div class="ai-image-text-slider-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            </div>
          {% endif %}
        </div>

        {% assign total_images = 0 %}
        {% for i in (1..5) %}
          {% assign image_key = 'image_' | append: i %}
          {% if block.settings[image_key] != blank %}
            {% assign total_images = total_images | plus: 1 %}
          {% endif %}
        {% endfor %}

        {% if total_images > 1 %}
          <div class="ai-image-text-slider-controls-{{ ai_gen_id }}">
            <button
              class="ai-image-text-slider-arrow-{{ ai_gen_id }} ai-image-text-slider-prev-{{ ai_gen_id }}"
              aria-label="Previous slide"
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="15 18 9 12 15 6"></polyline>
              </svg>
            </button>

            <div class="ai-image-text-slider-dots-{{ ai_gen_id }}">
              {% for i in (1..total_images) %}
                <button
                  class="ai-image-text-slider-dot-{{ ai_gen_id }} {% if i == 1 %}active{% endif %}"
                  data-index="{{ i | minus: 1 }}"
                  aria-label="Go to slide {{ i }}"
                ></button>
              {% endfor %}
            </div>

            <button
              class="ai-image-text-slider-arrow-{{ ai_gen_id }} ai-image-text-slider-next-{{ ai_gen_id }}"
              aria-label="Next slide"
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
            </button>
          </div>
        {% endif %}
      </div>

      <div class="ai-image-text-slider-content-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-image-text-slider-heading-{{ ai_gen_id }}">
            {{ block.settings.heading }}
          </h2>
        {% endif %}

        {% if block.settings.text != blank %}
          <div class="ai-image-text-slider-text-{{ ai_gen_id }}">
            {{ block.settings.text }}
          </div>
        {% endif %}

        {% if block.settings.button_text != blank %}
          <div>
            <a
              href="{{ block.settings.button_link }}"
              class="ai-image-text-slider-button-{{ ai_gen_id }}"
            >
              {{ block.settings.button_text }}
            </a>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</image-text-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageTextSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.totalSlides = 0;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-image-text-slider-track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-image-text-slider-slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-image-text-slider-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-image-text-slider-next-{{ ai_gen_id }}');
        this.dots = this.querySelectorAll('.ai-image-text-slider-dot-{{ ai_gen_id }}');

        this.totalSlides = this.slides.length;

        if (this.totalSlides <= 1) return;

        this.setupEventListeners();
        this.updateSlider();
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.goToPrevious());
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.goToNext());
        }

        this.dots.forEach((dot) => {
          dot.addEventListener('click', (e) => {
            const index = parseInt(e.target.dataset.index);
            this.goToSlide(index);
          });
        });

        let startX = 0;
        let endX = 0;

        this.track.addEventListener('touchstart', (e) => {
          startX = e.touches[0].clientX;
        });

        this.track.addEventListener('touchend', (e) => {
          endX = e.changedTouches[0].clientX;
          if (startX - endX > 50) {
            this.goToNext();
          } else if (endX - startX > 50) {
            this.goToPrevious();
          }
        });
      }

      goToPrevious() {
        this.currentIndex = this.currentIndex > 0 ? this.currentIndex - 1 : this.totalSlides - 1;
        this.updateSlider();
      }

      goToNext() {
        this.currentIndex = this.currentIndex < this.totalSlides - 1 ? this.currentIndex + 1 : 0;
        this.updateSlider();
      }

      goToSlide(index) {
        this.currentIndex = index;
        this.updateSlider();
      }

      updateSlider() {
        const offset = -this.currentIndex * 100;
        this.track.style.transform = `translateX(${offset}%)`;

        this.dots.forEach((dot, index) => {
          if (index === this.currentIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });

        if (this.prevButton) {
          this.prevButton.disabled = false;
        }

        if (this.nextButton) {
          this.nextButton.disabled = false;
        }
      }
    }

    customElements.define('image-text-slider-{{ ai_gen_id }}', ImageTextSlider{{ ai_gen_id }});
  })();
</script>

{% schema %}
