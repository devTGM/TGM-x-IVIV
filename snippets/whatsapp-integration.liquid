
<div id="whatsapp-popup" class="whatsapp-popup" style="display: none;">
  <div class="whatsapp-popup__content">
    <button class="whatsapp-popup__close" onclick="closeWhatsappPopup()">×</button>
    <h3>Get ₹50 OFF!</h3>
    <p>Subscribe to our WhatsApp updates and get a discount on your first order.</p>
    <div class="whatsapp-popup__form">
      <input type="tel" id="whatsapp-number" placeholder="Enter WhatsApp Number" class="whatsapp-popup__input">
      <button onclick="subscribeWhatsapp()" class="whatsapp-popup__button">Subscribe & Save</button>
    </div>
  </div>
</div>

<a href="https://wa.me/YOUR_NUMBER" class="whatsapp-float" target="_blank">
  <img src="https://upload.wikimedia.org/wikipedia/commons/6/6b/WhatsApp.svg" alt="WhatsApp" width="40" height="40">
</a>

<script>
  function showWhatsappPopup() {
    if (!localStorage.getItem('whatsapp_subscribed')) {
      document.getElementById('whatsapp-popup').style.display = 'flex';
    }
  }

  function closeWhatsappPopup() {
    document.getElementById('whatsapp-popup').style.display = 'none';
  }

  function subscribeWhatsapp() {
    const number = document.getElementById('whatsapp-number').value;
    if (number) {
      localStorage.setItem('whatsapp_subscribed', 'true');
      alert('Thank you for subscribing! Use code WHATSAPP50 for ₹50 off.');
      closeWhatsappPopup();
      // Here you would typically send the data to your backend or CRM
    } else {
      alert('Please enter a valid number.');
    }
  }

  // Show popup after 5 seconds
  setTimeout(showWhatsappPopup, 5000);
</script>

<style>
  .whatsapp-popup {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
  }
  .whatsapp-popup__content {
    background: #fff;
    padding: 30px;
    border-radius: 12px;
    max-width: 400px;
    width: 90%;
    text-align: center;
    position: relative;
    box-shadow: 0 10px 25px rgba(0,0,0,0.2);
  }
  .whatsapp-popup__close {
    position: absolute;
    top: 10px;
    right: 15px;
    background: none;
    border: none;
    font-size: 24px;
    cursor: pointer;
  }
  .whatsapp-popup__form {
    margin-top: 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .whatsapp-popup__input {
    padding: 12px;
    border: 1px solid #ddd;
    border-radius: 6px;
    font-size: 1rem;
  }
  .whatsapp-popup__button {
    background: #25d366;
    color: #fff;
    border: none;
    padding: 12px;
    border-radius: 6px;
    font-weight: bold;
    cursor: pointer;
    transition: background 0.3s;
  }
  .whatsapp-popup__button:hover {
    background: #128c7e;
  }
  .whatsapp-float {
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 1000;
    transition: transform 0.3s;
  }
  .whatsapp-float:hover {
    transform: scale(1.1);
  }
</style>
