
<div class="trust-bar section-padding" style="background-color: var(--color-off-white);">
  <div class="trust-bar__container page-width">
    {% for block in section.blocks %}
      <div class="trust-bar__item" {{ block.shopify_attributes }}>
        {% if block.settings.icon != blank %}
          <div class="trust-bar__icon">
            {{ block.settings.icon | image_url: width: 60 | image_tag: loading: 'lazy' }}
          </div>
        {% else %}
          <div class="trust-bar__icon-placeholder">
             {% comment %} Fallback or SVG icon scale {% endcomment %}
             <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M12 8v4l3 3"></path></svg>
          </div>
        {% endif %}
        <div class="trust-bar__text premium-small-caps">
          {{ block.settings.text | strip_html }}
        </div>
      </div>
    {% endfor %}
  </div>
</div>

{% stylesheet %}
  .trust-bar {
    border-top: 1px solid rgba(0,0,0,0.05);
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }
  .trust-bar__container {
    display: flex;
    justify-content: space-around;
    align-items: center;
    gap: 40px;
  }
  .trust-bar__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 15px;
    flex: 1;
  }
  .trust-bar__icon img {
    max-width: 35px;
    height: auto;
    opacity: 0.8;
  }
  .trust-bar__icon-placeholder {
    color: var(--color-gold-muted);
  }
  .trust-bar__text {
    max-width: 150px;
    text-align: center;
  }
  @media screen and (max-width: 749px) {
    .trust-bar__container {
      flex-wrap: wrap;
      gap: 20px;
    }
    .trust-bar__item {
      flex: 0 0 calc(50% - 10px);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Trust Bar (Premium)",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Trust Marker</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Bar (Premium)",
      "blocks": [
        { "type": "trust_item", "settings": { "text": "<p>100% Vegan</p>" } },
        { "type": "trust_item", "settings": { "text": "<p>Cruelty Free</p>" } },
        { "type": "trust_item", "settings": { "text": "<p>Same Day Dispatch</p>" } },
        { "type": "trust_item", "settings": { "text": "<p>4.8 Rating</p>" } }
      ]
    }
  ]
}
{% endschema %}
