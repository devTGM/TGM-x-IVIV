
<div class="about-psr section-padding" style="background-color: var(--color-off-white);">
  <div class="about-psr__container page-width page-width--narrow">
    <div class="about-psr__header text-center">
      <h2 class="about-psr__title h0">{{ section.settings.title }}</h2>
      <div class="about-psr__subtitle premium-small-caps">{{ section.settings.subtitle }}</div>
    </div>

    <div class="about-psr__editorial">
      <div class="about-psr__manifesto">
        <div class="about-psr__item">
          <div class="about-psr__label premium-small-caps">The Problem</div>
          <div class="about-psr__text premium-italic h2">{{ section.settings.problem_text | strip_html }}</div>
        </div>
        <div class="about-psr__divider"></div>
        <div class="about-psr__item">
          <div class="about-psr__label premium-small-caps">The Solution</div>
          <div class="about-psr__text premium-italic h2">{{ section.settings.solution_text | strip_html }}</div>
        </div>
        <div class="about-psr__divider"></div>
        <div class="about-psr__item">
          <div class="about-psr__label premium-small-caps">The Result</div>
          <div class="about-psr__text premium-italic h2">{{ section.settings.result_text | strip_html }}</div>
        </div>
      </div>
      
      {% if section.settings.image != blank or section.settings.video != blank %}
        <div class="about-psr__media">
          {% if section.settings.video != blank %}
            {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, class: 'about-psr__video' }}
          {% else %}
            {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'about-psr__img' }}
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
  .about-psr__header {
    margin-bottom: 80px;
  }
  .about-psr__title {
    margin-bottom: 10px;
    font-size: 4rem;
  }
  .about-psr__manifesto {
    display: flex;
    flex-direction: column;
    gap: 60px;
    align-items: center;
    max-width: 800px;
    margin: 0 auto 80px;
    text-align: center;
  }
  .about-psr__item {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .about-psr__label {
    color: var(--color-gold-muted);
  }
  .about-psr__text {
    line-height: 1.4;
    color: var(--color-charcoal);
  }
  .about-psr__divider {
    width: 60px;
    height: 1px;
    background: rgba(0,0,0,0.1);
  }
  .about-psr__media {
    overflow: hidden;
    border-radius: 4px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.05);
  }
  .about-psr__img, .about-psr__video {
    width: 100%;
    height: auto;
    display: block;
    filter: sepia(0.1);
  }
  @media screen and (max-width: 749px) {
    .about-psr__title {
      font-size: 2.5rem;
    }
    .about-psr__manifesto {
      gap: 40px;
    }
    .about-psr__text {
      font-size: 1.5rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "About Us PSR (Premium)",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Title",
      "default": "Our Manifesto"
    },
    {
      "type": "inline_richtext",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "CRAFTED WITH INTENT"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Featured Image"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Featured Video"
    },
    {
      "type": "richtext",
      "id": "problem_text",
      "label": "Problem",
      "default": "<p>Mass-produced accessories lack soul and durability.</p>"
    },
    {
      "type": "richtext",
      "id": "solution_text",
      "label": "Solution",
      "default": "<p>We source the finest materials to create functional art.</p>"
    },
    {
      "type": "richtext",
      "id": "result_text",
      "label": "Result",
      "default": "<p>Elegance that stands the test of time, on your waist.</p>"
    }
  ],
  "presets": [
    {
      "name": "About Us PSR (Premium)"
    }
  ]
}
{% endschema %}
