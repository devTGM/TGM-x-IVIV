
{{ 'section.css' | asset_url | stylesheet_tag }}

<div class="about-psr color-{{ section.settings.color_scheme }} spacing-style" style="{% render 'spacing-style', settings: section.settings %}">
  <div class="about-psr__container page-width">
    <div class="about-psr__grid {% if section.settings.layout == 'right' %}about-psr__grid--reverse{% endif %}">
      <div class="about-psr__media">
        {% if section.settings.video != blank %}
          {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, class: 'about-psr__video' }}
        {% elsif section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', class: 'about-psr__image' }}
        {% else %}
          {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>
      <div class="about-psr__content">
        <h2 class="about-psr__title h1">{{ section.settings.title }}</h2>
        <div class="about-psr__items">
          <div class="about-psr__item">
            <h3 class="about-psr__item-title h4">Problem:</h3>
            <div class="about-psr__item-text rte">{{ section.settings.problem_text }}</div>
          </div>
          <div class="about-psr__item">
            <h3 class="about-psr__item-title h4">Solution:</h3>
            <div class="about-psr__item-text rte">{{ section.settings.solution_text }}</div>
          </div>
          <div class="about-psr__item">
            <h3 class="about-psr__item-title h4">Result:</h3>
            <div class="about-psr__item-text rte">{{ section.settings.result_text }}</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .about-psr__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
  }
  .about-psr__grid--reverse {
    direction: rtl;
  }
  .about-psr__grid--reverse > * {
    direction: ltr;
  }
  .about-psr__media img, .about-psr__video {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 8px;
  }
  .about-psr__title {
    margin-bottom: 30px;
  }
  .about-psr__items {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .about-psr__item-title {
    font-weight: bold;
    margin-bottom: 5px;
    color: rgba(var(--color-foreground), 0.7);
  }
  @media screen and (max-width: 749px) {
    .about-psr__grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "About Us PSR",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "Media Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Title",
      "default": "About Us"
    },
    {
      "type": "richtext",
      "id": "problem_text",
      "label": "Problem",
      "default": "<p>Explain the problem here.</p>"
    },
    {
      "type": "richtext",
      "id": "solution_text",
      "label": "Solution",
      "default": "<p>Explain the solution here.</p>"
    },
    {
      "type": "richtext",
      "id": "result_text",
      "label": "Result",
      "default": "<p>Explain the result here.</p>"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "About Us PSR"
    }
  ]
}
{% endschema %}
