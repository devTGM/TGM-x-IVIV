
<div class="video-grid section-padding" style="background-color: var(--color-beige-muted);">
  <div class="video-grid__container page-width">
    {% if section.settings.title != blank %}
      <div class="video-grid__header text-center">
        <h2 class="video-grid__title h1">{{ section.settings.title }}</h2>
        <div class="video-grid__subtitle premium-small-caps">{{ section.settings.subtitle }}</div>
      </div>
    {% endif %}

    <div class="video-grid__items">
      {% for block in section.blocks %}
        <div class="video-grid__item" {{ block.shopify_attributes }}>
          <div class="video-grid__media">
            {% if block.settings.video != blank %}
              {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, class: 'video-grid__video' }}
            {% else %}
              {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
            <div class="video-grid__overlay">
               <div class="video-grid__caption premium-small-caps">{{ block.settings.label }}</div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% stylesheet %}
  .video-grid__header {
    margin-bottom: 60px;
  }
  .video-grid__title {
    margin-bottom: 10px;
  }
  .video-grid__items {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px; /* Minimalist seam */
    background: #fff;
    padding: 2px;
    border-radius: 4px;
    overflow: hidden;
  }
  .video-grid__item {
    position: relative;
    aspect-ratio: 9/16;
    overflow: hidden;
  }
  .video-grid__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }
  .video-grid__item:hover .video-grid__video {
    transform: scale(1.05);
  }
  .video-grid__overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 20px;
    background: linear-gradient(transparent, rgba(0,0,0,0.4));
    color: #fff;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .video-grid__item:hover .video-grid__overlay {
    opacity: 1;
  }
  @media screen and (max-width: 989px) {
    .video-grid__items {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media screen and (max-width: 749px) {
    .video-grid__items {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Video Grid (Premium)",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Title",
      "default": "Behind the Craft"
    },
    {
      "type": "inline_richtext",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "THE ART OF IVIV"
    }
  ],
  "blocks": [
    {
      "type": "video_item",
      "name": "Video Item",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Quality Detail"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video Grid (Premium)",
      "blocks": [
        { "type": "video_item", "settings": { "label": "The Stitch" } },
        { "type": "video_item", "settings": { "label": "The Finish" } },
        { "type": "video_item", "settings": { "label": "The Fit" } },
        { "type": "video_item", "settings": { "label": "The Soul" } }
      ]
    }
  ]
}
{% endschema %}
