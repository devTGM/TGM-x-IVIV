
<div class="faq-minimal section-padding" style="background-color: var(--color-off-white);">
  <div class="faq-minimal__container page-width page-width--narrow">
    {% if section.settings.title != blank %}
      <div class="faq-minimal__header text-center">
        <h2 class="faq-minimal__title h1">{{ section.settings.title }}</h2>
        <div class="faq-minimal__subtitle premium-small-caps">{{ section.settings.subtitle }}</div>
      </div>
    {% endif %}

    <div class="faq-minimal__list">
      {% for block in section.blocks %}
        <details class="faq-minimal__item" {{ block.shopify_attributes }}>
          <summary class="faq-minimal__question h3">
            {{ block.settings.question }}
            <span class="faq-minimal__icon"></span>
          </summary>
          <div class="faq-minimal__answer premium-body">
            {{ block.settings.answer }}
          </div>
        </details>
      {% endfor %}
    </div>
  </div>
</div>

{% stylesheet %}
  .faq-minimal__header {
    margin-bottom: 80px;
  }
  .faq-minimal__title {
    margin-bottom: 10px;
  }
  .faq-minimal__list {
    max-width: 800px;
    margin: 0 auto;
    border-top: 1px solid rgba(0,0,0,0.05);
  }
  .faq-minimal__item {
    border-bottom: 1px solid rgba(0,0,0,0.05);
    padding: 0;
  }
  .faq-minimal__question {
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 30px 0;
    cursor: pointer;
    transition: color 0.3s ease;
  }
  .faq-minimal__question::-webkit-details-marker {
    display: none;
  }
  .faq-minimal__question:hover {
    color: var(--color-gold-muted);
  }
  .faq-minimal__icon {
    position: relative;
    width: 20px;
    height: 20px;
  }
  .faq-minimal__icon::before, .faq-minimal__icon::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    height: 1px;
    background: currentColor;
    transition: transform 0.3s ease;
  }
  .faq-minimal__icon::after {
    transform: rotate(90deg);
  }
  details[open] .faq-minimal__icon::after {
    transform: rotate(0deg);
  }
  .faq-minimal__answer {
    padding-bottom: 40px;
    line-height: 1.6;
    color: var(--color-charcoal);
    opacity: 0.8;
  }
  .faq-minimal__answer p {
    margin: 0;
  }
  @media screen and (max-width: 749px) {
    .faq-minimal__question {
      font-size: 1.5rem;
      padding: 20px 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "FAQ (Premium Minimal)",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Title",
      "default": "Frequently Asked"
    },
    {
      "type": "inline_richtext",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "CARE & CRAFT"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How should I care for my belt?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Wipe with a soft, damp cloth. Avoid direct heat and store in the provided dust bag.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ (Premium Minimal)",
      "blocks": [
        { "type": "faq_item", "settings": { "question": "What is the return policy?", "answer": "<p>We offer a 30-day return policy for all unworn items in their original packaging.</p>" } },
        { "type": "faq_item", "settings": { "question": "Are the materials sustainable?", "answer": "<p>Yes, we prioritize ethically sourced leather and planet-friendly vegan alternatives.</p>" } }
      ]
    }
  ]
}
{% endschema %}
